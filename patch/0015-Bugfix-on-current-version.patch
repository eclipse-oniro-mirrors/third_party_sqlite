   sqlite3_stmt *stmt = NULL;
   const char *sql = "SELECT 1 FROM sqlite_master WHERE type='table' AND name=?;";
-  int exists = 0;
 
-  if( sqlite3_prepare_v2(db, sql, -1, &stmt, NULL)==SQLITE_OK ){

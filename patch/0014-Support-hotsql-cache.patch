 };
 
 /*
@@ -23977,6 +23989,12 @@ struct Vdbe {
   sqlite3_uint64 nDataTmp;        /* Size of pDataTmp */
 /* end of binlog related field */
 #endif
+#ifdef SQLITE_QUERY_CACHE
+  u8 *pCacheWriteBuf;
+  u8 *pCacheReadBuf;
+  int cacheReadPos;
+  int cacheFlags;
+#endif /* SQLITE_QUERY_CACHE */
 };
 
 /*
@@ -24033,6 +24051,3535 @@ struct ValueList {
 SQLITE_PRIVATE const u8 sqlite3SmallTypeSizes[];
 #endif
 
+/* fuction for hot sql cache begin */
+#ifdef SQLITE_QUERY_CACHE
+int sqlite3QCacheGetWALSalt(sqlite3 *db, u32 *salt1, u32 *salt2);
+int sqlite3QCacheGetSchemaCookie(sqlite3 *db, u32 *schemaCookie);
+int sqlite3QCacheGetChangeCounter(sqlite3 *db, u32 *chgCounter);
+/* Cache file path suffix */
+#define CACHE_FILE_SUFFIX ".qcache"
+#define QCACHE_HOTSQL_PREFIX_1 "select"
+#define QCACHE_HOTSQL_PREFIX_1_LEN 6u
+#define QCACHE_HOTSQL_PREFIX_2 "with"
+#define QCACHE_HOTSQL_PREFIX_2_LEN 4u
+#define QCACHE_PAGE_WLOCK 1u
+#define QCACHE_PAGE_RLOCK 0u
+#define QCACHE_ALIGN_UP_TO_4KB_BYTES(kb_value) ((((kb_value) + 3) & ~3) << 10)
+#define QCACHE_DEBUG_BUFFER_2MB (2 * 1024 * 1024)
+#define QCACHE_INSTANCE_LOCK_SUFFIX ".lock"
+#define QCACHE_DEBUG_PRINT_LEN (700)
+#define QCACHE_SQLSTR_POOL_MAX (10u)
+#define QCACHE_SQLSTR_MEM_SIZE (512u)
+#define QCACHE_CONTAINER_OF(ptr, type, member) ((type*)((unsigned char*)(ptr) - offsetof(type, member)))
+#define QCACHE_GET_MEMBLOCK_FROM_DATA(data_ptr) QCACHE_CONTAINER_OF(data_ptr, QCacheMemBlock, data)
+#define QCACHE_MEMBLOCK_2_DATA(block_ptr) (((block_ptr)->data))
+
+static QCacheMemBlockPool g_QCacheMemPool = {0};
+static QCacheMemBlockPool *qCacheGetMemBlockPool(void)
+{
+    return &g_QCacheMemPool;
+}
+
+static QCacheMemBlock *qCacheCreateMemBlock(size_t size)
+{
+    size_t headLen = sizeof(QCacheMemBlock);
+    size_t dataLen = (size <= QCACHE_SQLSTR_MEM_SIZE) ? QCACHE_SQLSTR_MEM_SIZE : size;
+    QCacheMemBlock *block = (QCacheMemBlock*)sqlite3_malloc(headLen + dataLen);
+    if (block == NULL) {
+        return NULL;
+    }
+
+    block->isFromPool = 0;
+    block->dataLen = dataLen;
+    block->next = NULL;
+    memset(block->data, 0, block->dataLen);
+
+    return block;
+}
+
+int qCacheInitMemBlockPool(int maxCount)
+{
+    QCacheMemBlockPool *pool = qCacheGetMemBlockPool();
+    if (pthread_mutex_init(&pool->mutex, NULL) != 0) {
+        sqlite3_log(SQLITE_IOERR, "qCacheInitMemBlockPool, pthread_mutex_init failed, errno %d.", errno);
+        return SQLITE_IOERR;
+    }
+
+    pool->maxCount = maxCount;
+    pool->totalCount = 0;
+    pool->freeCount = 0;
+    pool->pool = NULL;
+
+    return SQLITE_OK;
+}
+
+void qCacheDestroyMemBlockPool(void)
+{
+    QCacheMemBlockPool *pool = qCacheGetMemBlockPool();
+
+    pthread_mutex_lock(&pool->mutex);
+    QCacheMemBlock *curr = pool->pool;
+    while (curr != NULL) {
+        QCacheMemBlock *next = curr->next;
+        sqlite3_free(curr);
+        curr = next;
+    }
+
+    pool->pool = NULL;
+    pool->maxCount = 0;
+    pool->totalCount = 0;
+    pool->freeCount = 0;
+    pthread_mutex_unlock(&pool->mutex);
+    pthread_mutex_destroy(&pool->mutex);
+}
+
+void qCacheRegMemBlockPoolCleanUp(void)
+{
+    atexit(qCacheDestroyMemBlockPool);
+}
+
+QCacheMemBlock *qCacheMemBlockPoolAlloc(size_t size)
+{
+    if (size == 0) {
+        return NULL;
+    }
+
+    if (size > QCACHE_SQLSTR_MEM_SIZE) {
+        return qCacheCreateMemBlock(size);
+    }
+
+    QCacheMemBlock *block = NULL;
+    QCacheMemBlockPool *pool = qCacheGetMemBlockPool();
+    pthread_mutex_lock(&pool->mutex);
+    if (pool->pool) {
+        block = pool->pool;
+        pool->pool = block->next;
+        pool->freeCount--;
+    } else {
+        block = qCacheCreateMemBlock(size);
+        if (block) {
+            if (pool->totalCount < pool->maxCount) {
+                block->isFromPool = 1;
+                pool->totalCount++;
+            } else {
+                block->isFromPool = 0;
+            }
+        }
+    }
+    pthread_mutex_unlock(&pool->mutex);
+
+    if (block == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "qCacheMemBlockPoolAlloc, create mem block, errno %d.", errno);
+        return NULL;
+    }
+
+    if (block->isFromPool) {
+        block->next = NULL;
+        memset(block->data, 0, block->dataLen);
+    }
+
+    return block;
+}
+
+char *qCacheMemBlockPoolAllocMem(size_t allocSize)
+{
+    QCacheMemBlock *memBlock = qCacheMemBlockPoolAlloc(allocSize);
+    if (!memBlock) {
+        sqlite3_log(SQLITE_NOMEM, "qCacheMemBlockPoolAllocMem(): qCacheMemBlockPoolAlloc.");
+        return NULL;
+    }
+
+    return QCACHE_MEMBLOCK_2_DATA(memBlock);
+}
+
+void qCacheMemBlockPoolFree(QCacheMemBlock *block)
+{
+    if (block == NULL) {
+        return;
+    }
+
+    if (!block->isFromPool) {
+        sqlite3_free(block);
+        return;
+    }
+
+    QCacheMemBlockPool *pool = qCacheGetMemBlockPool();
+    pthread_mutex_lock(&pool->mutex);
+    block->next = pool->pool;
+    pool->pool = block;
+    pool->freeCount++;
+    pthread_mutex_unlock(&pool->mutex);
+}
+
+void qCacheMemBlockPoolFreeMem(char *ptr)
+{
+    QCacheMemBlock *block = QCACHE_GET_MEMBLOCK_FROM_DATA(ptr);
+    qCacheMemBlockPoolFree(block);
+}
+
+static __thread char *g_QCacheDebugBuffer = NULL;
+
+void qCacheDebugAppend(const char *fmt, ...)
+{
+    if (!g_QCacheDebugBuffer) {
+        char *tmpBuf = sqlite3_malloc(QCACHE_DEBUG_BUFFER_2MB);
+        if (!tmpBuf) {
+            return;
+        }
+        tmpBuf[0] = '\0';
+        g_QCacheDebugBuffer = tmpBuf;
+    }
+
+    int usedLen = (int)strlen(g_QCacheDebugBuffer);
+    int freeLen = (int)QCACHE_DEBUG_BUFFER_2MB - usedLen - 1;
+    if (freeLen <= 0) {
+        return;
+    }
+
+    va_list ap;
+    va_start(ap, fmt);
+    vsnprintf(g_QCacheDebugBuffer + usedLen, freeLen + 1, fmt, ap);
+    va_end(ap);
+}
+
+void qCacheDebugPrint(void)
+{
+    if (!g_QCacheDebugBuffer || g_QCacheDebugBuffer[0] == '\0') {
+        return;
+    }
+
+    const int chunkSize = QCACHE_DEBUG_PRINT_LEN - 1;
+    char printBuf[QCACHE_DEBUG_PRINT_LEN] = {0};
+    char *p = g_QCacheDebugBuffer;
+
+    while (*p) {
+        int len = strlen(p);
+        int printLen = len < chunkSize ? len : chunkSize;
+        memset(printBuf, 0, sizeof(printBuf));
+        memmove(printBuf, p, printLen);
+        sqlite3_log(SQLITE_NOTICE, "%s", printBuf);
+        p += printLen;
+    }
+
+    sqlite3_free(g_QCacheDebugBuffer);
+    g_QCacheDebugBuffer = NULL;
+}
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+void qCachePrintFulllog(int errCode, const char *format, ...)
+{
+#define QCACHE_PFULL_MAX 200u
+    if (!format) return;
+
+    va_list args1, args2;
+    va_start(args1, format);
+    va_copy(args2, args1);
+    int len = vsnprintf(NULL, 0, format, args1);
+    va_end(args1);
+
+    if (len < 0) {
+        va_end(args2);
+        return;
+    }
+
+    int allLen = len + 2;
+    char *fullMsg = (char*)sqlite3_malloc(allLen);  // +2 for '\n' and '\0'
+    if (!fullMsg) {
+        va_end(args2);
+        return;
+    }
+    memset(fullMsg, 0, allLen);
+
+    vsnprintf(fullMsg, allLen - 1, format, args2);
+    va_end(args2);
+
+    const int chunkSize = QCACHE_PFULL_MAX - 1;
+    char printBuf[QCACHE_PFULL_MAX] = {0};
+    char *p = fullMsg;
+    while (*p) {
+        int len = strlen(p);
+        int printLen = len < chunkSize ? len : chunkSize;
+        memset(printBuf, 0, sizeof(printBuf));
+        memmove(printBuf, p, printLen);
+        if (printLen < chunkSize) {
+            sqlite3_log(SQLITE_ERROR, "%s\n", printBuf);
+        } else {
+            sqlite3_log(SQLITE_ERROR, "%s", printBuf);
+        }
+        p += printLen;
+    }
+
+    sqlite3_free(fullMsg);
+}
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+static int getCacheFileSize(const char *cacheFilePath, u32 *fileSize)
+{
+    if (!cacheFilePath) {
+        return SQLITE_MISUSE;
+    }
+
+    struct stat st;
+    int ret = stat(cacheFilePath, &st);
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR, "stat error(%s)", strerror(errno));
+        return SQLITE_IOERR;
+    }
+
+    *fileSize = (u32)st.st_size;
+    return SQLITE_OK;
+}
+
+static pthread_rwlock_t g_QCacheShmRWlock = PTHREAD_RWLOCK_INITIALIZER;
+int sharePageWRLock(int fd, u8 isWrite)
+{
+    int ret = SQLITE_OK;
+    if (isWrite) {
+        ret = pthread_rwlock_wrlock(&g_QCacheShmRWlock);
+    } else {
+        ret = pthread_rwlock_rdlock(&g_QCacheShmRWlock);
+    }
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR_LOCK, "rwlock %u, error(%s)", isWrite, strerror(errno));
+        return SQLITE_IOERR_LOCK;
+    }
+
+    if (isWrite) {
+        ret = flock(fd, LOCK_EX);
+    } else {
+        ret = flock(fd, LOCK_SH);
+    }
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR_LOCK, "flock lock error(%s)", strerror(errno));
+        pthread_rwlock_unlock(&g_QCacheShmRWlock);
+        return SQLITE_IOERR_LOCK;
+    }
+
+    return SQLITE_OK;
+}
+
+void sharePageUnLock(int fd)
+{
+    int ret = flock(fd, LOCK_UN);
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR_UNLOCK, "flock unlock error(%s)", strerror(errno));
+    }
+
+    ret = pthread_rwlock_unlock(&g_QCacheShmRWlock);
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR_UNLOCK, "rwlock unlock error(%s)", strerror(errno));
+    }
+}
+
+int sharePageCheckCrc32(SBlkPage *page)
+{
+    return SQLITE_OK;
+}
+
+void sharePageSetCrc32(SBlkPage *page)
+{}
+
+SBlkRowAddr sharePageGetRowAddrById(SBlkPage *page, SBlkSlotID slotId)
+{
+    return *((SBlkRowAddr *)((u8 *)page + page->head.tailOffset - (slotId + 1) * sizeof(SBlkRowAddr)));
+}
+
+u8 *sharePageRowGetPayload(SBlkRowHead *rowHead)
+{
+    return ((u8 *)rowHead + sizeof(SBlkRowHead));
+}
+
+u32 sharePageRowGetPayloadLen(SBlkRowHead *rowHead)
+{
+    return (rowHead->len - sizeof(SBlkRowHead));
+}
+
+u32 sharePageGetTotalSize(SBlkPage *page)
+{
+    return page->head.totalSize;
+}
+
+SBlkSlotID sharePageGetSqlDataSlotID(SBlkRowHead *sqlRowHead)
+{
+    if (sqlRowHead->type != SBLKR_TYPE_SQL) {
+        return SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    }
+
+    u8 *start = (u8 *)sqlRowHead;
+    return *((SBlkSlotID *)(start + sqlRowHead->len - sizeof(SBlkSlotID)));
+}
+
+void sharePageSetSqlDataSlotID(SBlkRowHead *sqlRowHead, SBlkSlotID dataSlotId)
+{
+    if (sqlRowHead->type != SBLKR_TYPE_SQL) {
+        return;
+    }
+
+    u8 *start = (u8 *)sqlRowHead;
+    SBlkSlotID *targetSlotId = (SBlkSlotID *)(start + sqlRowHead->len - sizeof(SBlkSlotID));
+    *targetSlotId = dataSlotId;
+}
+
+/*
+** +---------------------------------------------+
+** |  cksum    |  SBlkPgHead |  row1  |   row2   |
+** +-------------------                          +
+** |beginPos                                     |
+** |                    Data Region              |
+** |                                             |
+** +                            -----------------+
+** |         endPos|slot2|slot1|    SBlkPgTail   |
+** +---------------------------------------------+
+*/
+int sharePageInit(u8 *shmMem, u32 totalSize, u32 maxRowSize, SBlkPage **newPage)
+{
+    if (shmMem == NULL || totalSize <= sizeof(SBlkPage) + sizeof(SBlkPgTail)) {
+        /* Invalid parameter: total size must be larger than page struct size */
+        sqlite3_log(SQLITE_MISUSE, "invalid totalSize %u.", totalSize);
+        return SQLITE_MISUSE;
+    }
+
+    memset(shmMem, 0, totalSize);
+    SBlkPage *page = (SBlkPage *)shmMem;
+    SBlkPgHead *pg_head = &page->head;
+    pg_head->magic = SHARED_BLOCK_PAGE_MAGIC; /* Magic number for valid page */
+    pg_head->version = SHARED_BLOCK_PAGE_VERSION;
+    pg_head->startOffset = sizeof(SBlkPage);              /* Start offset of row data */
+    pg_head->tailOffset = totalSize - sizeof(SBlkPgTail); /* Page tail offset */
+    pg_head->beginPos = sizeof(SBlkPage);
+    pg_head->endPos = pg_head->tailOffset;
+    pg_head->totalSize = totalSize; /* Total size from input */
+    pg_head->freeSize = totalSize - sizeof(SBlkPage) - sizeof(SBlkPgTail);
+    pg_head->maxRowSize = maxRowSize;
+    pg_head->slotCnt = 0u; /* No slots used */
+
+    SBlkPgTail *pg_tail = (SBlkPgTail *)((u8 *)page + pg_head->tailOffset);
+    pg_tail->magic = SHARED_BLOCK_PAGE_MAGIC;
+    sharePageSetCrc32(page);
+    *newPage = page;
+    return SQLITE_OK;
+}
+
+int sharePageMakeUpSlotMap(SBlkPage *page, SBlkSlotID *slot_remap, SBlkSlotID *valid_slot_count)
+{
+    SBlkPgHead *pg_head = &page->head;
+    SBlkSlotID scanned = 0;
+    SBlkSlotID new_slot_counter = 0;
+    u32 current_scan_off = pg_head->startOffset;
+
+    while (current_scan_off < pg_head->endPos && scanned < pg_head->slotCnt) {
+        SBlkRowHead *row = (SBlkRowHead *)((u8 *)page + current_scan_off);
+        if (row->len <= sizeof(SBlkRowHead) || row->len > pg_head->maxRowSize) {
+            sqlite3_log(SQLITE_CORRUPT, "sharePageCompress4Free(): invalid row len %u", row->len);
+            return SQLITE_CORRUPT;
+        }
+
+        if (row->state == SBLKR_STATE_USED) {
+            slot_remap[scanned] = new_slot_counter;
+            new_slot_counter++;
+        }
+
+        scanned++;
+        current_scan_off += row->len;
+    }
+
+    *valid_slot_count = new_slot_counter;
+    return SQLITE_OK;
+}
+
+void sharePageUpdateSQLdataSlot(SBlkPage *page, SBlkRowHead *row, SBlkSlotID *slot_remap, SBlkSlotID valid_slots)
+{
+    if (row->state != SBLKR_STATE_USED || row->type != SBLKR_TYPE_SQL) {
+        return;
+    }
+
+    SBlkSlotID old_slot = sharePageGetSqlDataSlotID(row);
+    if (old_slot == SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+        return;
+    }
+
+    SBlkPgHead *pg_head = &page->head;
+    if (old_slot < pg_head->slotCnt) {
+        SBlkSlotID new_slot = slot_remap[old_slot];
+        if (new_slot != SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+            sharePageSetSqlDataSlotID(row, new_slot);
+        } else {
+            sqlite3_log(SQLITE_WARNING, "sharePageCompress4Free(): SQL row slot %u points to deleted data slot %u",
+                valid_slots, old_slot);
+            sharePageSetSqlDataSlotID(row, new_slot);
+        }
+    } else {
+        sqlite3_log(SQLITE_WARNING, "sharePageCompress4Free(): invalid slot number %u", old_slot);
+        sharePageSetSqlDataSlotID(row, SHARED_BLOCK_PAGE_INVALID_SLOTID);
+    }
+}
+
+/*
+** Compact the page to free up space. Defragment and move only valid rows
+** to the beginning of the data area, and rebuild the slot index at the end.
+** Return SQLITE_OK on success, or SQLITE_MISMATCH if corruption is detected.
+*/
+int sharePageCompress4Free(SBlkPage *page, int *toRebuild)
+{
+    *toRebuild = 0;
+    SBlkPgHead *pg_head = &page->head;
+    if (pg_head->slotCnt == 0) {
+        pg_head->freeSize = pg_head->endPos - pg_head->beginPos;
+        return SQLITE_OK;
+    }
+
+    u32 allocMapSize = pg_head->slotCnt * sizeof(SBlkSlotID);
+    SBlkSlotID *slot_remap = (SBlkSlotID *)sqlite3_malloc(allocMapSize);
+    if (!slot_remap) {
+        return SQLITE_NOMEM;
+    }
+    memset(slot_remap, 0xFF, allocMapSize);
+
+    SBlkSlotID valid_slot_count = 0;
+    int ret = sharePageMakeUpSlotMap(page, slot_remap, &valid_slot_count);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageCompress4Free(): sharePageMakeUpSlotMap.");
+        sqlite3_free(slot_remap);
+        return ret;
+    }
+
+    if (valid_slot_count == pg_head->slotCnt) {
+        sqlite3_free(slot_remap);
+        return SQLITE_OK;
+    }
+
+    SBlkSlotID valid_slots = 0;
+    SBlkSlotID scan_slots = 0;
+    u32 write_offset = pg_head->startOffset;
+    u32 current_offset = pg_head->startOffset;
+    while (current_offset < pg_head->endPos && scan_slots < pg_head->slotCnt) {
+        SBlkRowHead *row = (SBlkRowHead *)((u8 *)page + current_offset);
+        if (row->state == SBLKR_STATE_USED) {
+            sharePageUpdateSQLdataSlot(page, row, slot_remap, valid_slots);
+            if (current_offset != write_offset) {
+                memmove((u8 *)page + write_offset, row, row->len);
+                row = (SBlkRowHead *)((u8 *)page + write_offset);
+            }
+
+            u32 slot_addr_offset = pg_head->tailOffset - ((valid_slots + 1) * sizeof(SBlkRowAddr));
+            SBlkRowAddr *row_addr = (SBlkRowAddr *)((u8 *)page + slot_addr_offset);
+            *row_addr = write_offset;
+
+            valid_slots++;
+            write_offset += row->len;
+        }
+
+        scan_slots++;
+        current_offset += row->len;
+    }
+    sqlite3_free(slot_remap);
+
+    pg_head->beginPos = write_offset; /* Reset start of data region */
+    pg_head->endPos = pg_head->tailOffset - valid_slots * sizeof(SBlkRowAddr);
+    pg_head->slotCnt = valid_slots;                           /* Number of valid slots */
+    pg_head->freeSize = pg_head->endPos - pg_head->beginPos;
+    if (pg_head->freeSize > 0) {
+        memset((u8 *)page + pg_head->beginPos, 0, pg_head->freeSize);
+    }
+
+    sqlite3_log(SQLITE_OK, "After compressed from %u slots to %u slots, free space=%u", scan_slots, valid_slots,
+        pg_head->freeSize);
+    *toRebuild = 1;
+
+    return SQLITE_OK;
+}
+
+SBlkPage *sharePageExpand4Free(void *mapAddr, u32 newPageSize)
+{
+    SBlkPage *page = (SBlkPage *)mapAddr;
+    SBlkPgHead *pg_head = &page->head;
+    u32 oldEndPos = pg_head->endPos;
+    u32 oldFreeSize = pg_head->freeSize;
+    u32 oldPageSize = pg_head->totalSize;
+    pg_head->tailOffset = newPageSize - sizeof(SBlkPgTail);
+    pg_head->endPos = oldEndPos + (newPageSize - oldPageSize);
+    pg_head->freeSize = oldFreeSize + (newPageSize - oldPageSize);
+    pg_head->totalSize = newPageSize;
+
+    /* Move data from old endPos to the new location to preserve data */
+    u32 dataToMoveSize = oldPageSize - oldEndPos;
+    if (dataToMoveSize > 0) {
+        u8 *src = (u8 *)page + oldEndPos;
+        u8 *dst = (u8 *)page + pg_head->endPos;
+        memmove(dst, src, dataToMoveSize);
+    }
+
+    return page;
+}
+
+u32 sharePageGetRowSize(SBlkRowType type, u32 payloadSize)
+{
+    u32 baseSize = sizeof(SBlkRowHead) + payloadSize;
+    return (type == SBLKR_TYPE_SQL) ? (baseSize + sizeof(SBlkSlotID)) : baseSize;
+}
+
+/*
+** Validate the magic number.
+*/
+static int sharePageCheckMagic(u64 magic)
+{
+    if (magic != SHARED_BLOCK_PAGE_MAGIC) {
+        sqlite3_log(SQLITE_CORRUPT, "sharePageCheckMagic(): invalid magic number.");
+        return SQLITE_CORRUPT;
+    }
+    return SQLITE_OK;
+}
+
+/*
+** Validate all offset fields.
+*/
+static int sharePageHeadCheckOffset(SBlkPgHead *pg_head)
+{
+    /* Validate startOffset */
+    if (pg_head->startOffset != sizeof(SBlkPage)) {
+        sqlite3_log(SQLITE_CORRUPT, "sharePageHeadCheckOffset(): invalid startOffset %u.", pg_head->startOffset);
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate tailOffset */
+    if (pg_head->tailOffset < sizeof(SBlkPage) || pg_head->tailOffset >= pg_head->totalSize) {
+        sqlite3_log(SQLITE_CORRUPT,
+            "sharePageHeadCheckOffset(): invalid tailOffset %u, totalSize %u.",
+            pg_head->tailOffset,
+            pg_head->totalSize);
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate beginPos */
+    if (pg_head->beginPos < sizeof(SBlkPage) || pg_head->beginPos > pg_head->tailOffset) {
+        sqlite3_log(SQLITE_CORRUPT,
+            "sharePageHeadCheckOffset(): invalid beginPos %u, tailOffset %u.",
+            pg_head->beginPos,
+            pg_head->tailOffset);
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate endPos */
+    if (pg_head->endPos < pg_head->beginPos || pg_head->endPos > pg_head->tailOffset) {
+        sqlite3_log(SQLITE_CORRUPT,
+            "sharePageHeadCheckOffset(): invalid endPos %u, beginPos %u, tailOffset %u.",
+            pg_head->endPos,
+            pg_head->beginPos,
+            pg_head->tailOffset);
+        return SQLITE_CORRUPT;
+    }
+
+    return SQLITE_OK;
+}
+
+/*
+** Validate size-related fields.
+*/
+static int sharePageHeadCheckSize(SBlkPgHead *pg_head)
+{
+    /* Validate totalSize */
+    u32 minSize = sizeof(SBlkPage) + sizeof(SBlkPgTail);
+    if (pg_head->totalSize < minSize) {
+        sqlite3_log(
+            SQLITE_CORRUPT, "sharePageHeadCheckSize(): invalid totalSize %u, minSize %u.", pg_head->totalSize, minSize);
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate freeSize */
+    u32 continueSpace = pg_head->endPos - pg_head->beginPos;
+    if (pg_head->freeSize < continueSpace) {
+        sqlite3_log(
+            SQLITE_CORRUPT, "sharePageHeadCheckSize(): invalid freeSize %u, expect %u.", pg_head->freeSize, continueSpace);
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate slotCnt */
+    u32 maxSlotCnt = (pg_head->tailOffset - pg_head->startOffset) / sizeof(SBlkRowAddr);
+    if (pg_head->slotCnt > maxSlotCnt) {
+        sqlite3_log(
+            SQLITE_CORRUPT, "sharePageHeadCheckSize(): invalid slotCnt %u, maxSlotCnt %u.", pg_head->slotCnt, maxSlotCnt);
+        return SQLITE_CORRUPT;
+    }
+
+    return SQLITE_OK;
+}
+
+static int sharePageHeadCheckVersion(SBlkPgHead *pg_head)
+{
+    return (pg_head->version == SHARED_BLOCK_PAGE_VERSION) ? SQLITE_OK : SQLITE_MISMATCH;
+}
+
+/*
+** Validate all members of the SBlkPgHead structure.
+**
+** page:    Pointer to the page to validate.
+**
+** Return SQLITE_OK if the page header is valid.
+** Return an error code if corruption or misuse is detected.
+*/
+int sharePageHeadCheck(SBlkPage *page)
+{
+    if (!page) {
+        sqlite3_log(SQLITE_MISUSE, "sharePageHeadCheck(): page is NULL.");
+        return SQLITE_MISUSE;
+    }
+
+    SBlkPgHead *pg_head = &page->head;
+    int ret = sharePageHeadCheckVersion(pg_head);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    ret = sharePageHeadCheckOffset(pg_head);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    ret = sharePageHeadCheckSize(pg_head);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    /* Validate Tail magic */
+    SBlkPgTail *pg_tail = (SBlkPgTail *)((u8 *)page + pg_head->tailOffset);
+    if (sharePageCheckMagic(pg_head->magic) != SQLITE_OK || sharePageCheckMagic(pg_tail->magic) != SQLITE_OK) {
+        return SQLITE_CORRUPT;
+    }
+    return SQLITE_OK;
+}
+
+int sharePageValidCheck(SBlkPage *page)
+{
+    int ret = sharePageCheckCrc32(page);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageValidCheck(): sharePageCheckCrc32 failed.");
+        return ret;
+    }
+
+    ret = sharePageHeadCheck(page);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageValidCheck(): sharePageHeadCheck failed.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int sharePageAttach(u8 *shmMem, u32 attachSize, u32 *newPgSize, SBlkPage **page)
+{
+    SBlkPage *attachPage = (SBlkPage *)shmMem;
+    u32 curPgSize = sharePageGetTotalSize(attachPage);
+    if (curPgSize != attachSize) {
+        sqlite3_log(SQLITE_CORRUPT, "sharePageAttach(): page size misMatch.");
+        *newPgSize = curPgSize;
+        return SQLITE_CORRUPT;
+    }
+
+    /* Validate page integrity */
+    int ret = sharePageValidCheck(attachPage);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageAttach(): sharePageValidCheck failed.");
+        return SQLITE_CORRUPT;
+    }
+
+    attachPage->restoreMode = 1;
+    *page = attachPage;
+    return SQLITE_OK;
+}
+
+int sharePageBasicCheck(SBlkPage *page, SBlkRowType type)
+{
+    if (!page || page->head.magic != SHARED_BLOCK_PAGE_MAGIC) {
+        sqlite3_log(SQLITE_MISUSE, "sharePageBasicCheck(): invalid page.");
+        return SQLITE_MISUSE;
+    }
+
+    if (type < SBLKR_TYPE_SQL || type >= SBLKR_TYPE_MAX) {
+        sqlite3_log(SQLITE_MISUSE, "sharePageBasicCheck(): invalid type %u.", type);
+        return SQLITE_MISUSE;
+    }
+
+    return SQLITE_OK;
+}
+
+int sharePageParamCheck(SBlkPage *page, SBlkRowType type, u8 *payload, u32 payloadSize)
+{
+    int ret = sharePageBasicCheck(page, type);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    if (!payload || payloadSize == 0) {
+        return SQLITE_MISUSE;
+    }
+
+    return SQLITE_OK;
+}
+
+/*
+** |     SBlkRowHead    |   payload |   SBlkSlotID  |        // For SBLKR_TYPE_SQL row
+** |     SBlkRowHead    |   payload |                        // For SBLKR_TYPE_DATA row
+*/
+int sharePageInsertRow4Free(
+    SBlkPage *page,
+    SBlkRowType type,
+    QCacheVersion *ver,
+    u8 *payload,
+    u32 payloadSize,
+    SBlkSlotID *newSlotId)
+{
+    int ret = sharePageParamCheck(page, type, payload, payloadSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageParamCheck().");
+        return ret;
+    }
+
+    u32 rowTotalSize = sharePageGetRowSize(type, payloadSize);
+    u32 rowNeedSize = rowTotalSize + sizeof(SBlkRowAddr);
+    SBlkPgHead *pg_head = &page->head;
+
+    if (rowNeedSize > pg_head->maxRowSize) {
+        /* Size check: exceeds single row maximum limit */
+        sqlite3_log(SQLITE_TOOBIG, "sharePageInsertRow4Free(): too big row.");
+        return SQLITE_TOOBIG;
+    }
+
+    if (rowNeedSize > pg_head->freeSize) {
+        /* Space check: insufficient free space on page */
+        sqlite3_log(SQLITE_NOMEM, "sharePageInsertRow4Free(): no enough space, freeSize %u, needSize %u.",
+            pg_head->freeSize, rowNeedSize);
+        return SQLITE_NOMEM;
+    }
+
+    /* Check if contiguous space is available */
+    if ((pg_head->endPos - pg_head->beginPos) < rowNeedSize) {
+        sqlite3_log(SQLITE_NOMEM, "sharePageInsertRow4Free(): no continous space, freeSize %u, needSize %u.",
+            pg_head->freeSize, rowNeedSize);
+        return SQLITE_NOMEM;
+    }
+
+    /* Allocate memory from beginPos */
+    u32 rowOffset = pg_head->beginPos;
+    SBlkRowHead *row = (SBlkRowHead *)((u8 *)page + rowOffset);
+    row->state = SBLKR_STATE_USED; /* Mark row as in use */
+    row->type = type;              /* Set row type */
+    row->len = rowTotalSize;       /* Total length of this row */
+    row->ver = *ver;
+
+    /* Copy payload data */
+    u8 *rowPayload = (u8 *)row + sizeof(SBlkRowHead);
+    memcpy(rowPayload, payload, payloadSize);
+
+    /* For SQL type row: initialize slot ID to invalid */
+    if (type == SBLKR_TYPE_SQL) {
+        SBlkSlotID *slotId = (SBlkSlotID *)(rowPayload + payloadSize);
+        *slotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    }
+
+    /* Assign slot ID for this row */
+    SBlkRowAddr *rowAddr = (SBlkRowAddr *)(((u8 *)page + pg_head->endPos) - sizeof(SBlkRowAddr));
+    *rowAddr = rowOffset;
+    *newSlotId = pg_head->slotCnt;
+
+    /* Update page metadata */
+    pg_head->slotCnt++;
+    pg_head->beginPos += rowTotalSize;
+    pg_head->endPos -= sizeof(SBlkRowAddr);
+    pg_head->freeSize -= rowNeedSize;
+
+    return SQLITE_OK;
+}
+
+int sharePageInsertRow4FreeCrc32(
+    SBlkPage *page,
+    SBlkRowType type,
+    QCacheVersion *ver,
+    u8 *payload,
+    u32 payloadSize,
+    SBlkSlotID *newSlotId)
+{
+    int ret = sharePageInsertRow4Free(page, type, ver, payload, payloadSize, newSlotId);
+    if (ret == SQLITE_OK) {
+        sharePageSetCrc32(page);
+        msync(page, page->head.totalSize, MS_SYNC);
+    }
+
+    return ret;
+}
+
+static inline int sharePageRowBasicCheck(SBlkPage *page, SBlkRowHead *rowHead)
+{
+    if (rowHead->state != SBLKR_STATE_USED || rowHead->type >= SBLKR_TYPE_MAX || rowHead->type < SBLKR_TYPE_SQL ||
+        rowHead->len > page->head.maxRowSize) {
+        return SQLITE_MISUSE;
+    }
+
+    return SQLITE_OK;
+}
+
+/*
+** Find a row by slotId. 4Free: No locking.
+**
+** page:      Shared memory page pointer.
+** slotId:    Slot ID of the row to locate.
+** rowHead:   Output: Pointer to the row header.
+**
+** Return SQLITE_OK on success, error code on failure.
+*/
+int sharePageFindRow4Free(SBlkPage *page, SBlkSlotID slotId, SBlkRowHead **rowHead)
+{
+    SBlkPgHead *pg_head = &page->head;
+    if (slotId >= pg_head->slotCnt) {
+        sqlite3_log(SQLITE_MISUSE, "sharePageFindRow4Free(): invalid slotId %u, maxSlot %u.", slotId, pg_head->slotCnt);
+        return SQLITE_MISUSE;
+    }
+
+    SBlkRowAddr rowOffset = sharePageGetRowAddrById(page, slotId);
+    /* Validate offset (must be within data region) */
+    if (rowOffset < sizeof(SBlkPage) || rowOffset >= pg_head->endPos) {
+        sqlite3_log(SQLITE_MISUSE, "sharePageFindRow4Free(): invalid offset %u.", rowOffset);
+        return SQLITE_MISUSE;
+    }
+
+    SBlkRowHead *foundHead = (SBlkRowHead *)((u8 *)page + rowOffset);
+    int ret = sharePageRowBasicCheck(page, foundHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageFindRow4Free(): invalid row.");
+        *rowHead = foundHead;
+        return ret;
+    }
+    *rowHead = foundHead;
+    return SQLITE_OK;
+}
+
+int sharePageCmpSqlRow4Free(SBlkPage *page, SBlkSlotID slotId, const char *hotSql, u8 *isMatched)
+{
+    *isMatched = 0;
+    SBlkRowHead *rowHead = NULL;
+    int ret = sharePageFindRow4Free(page, slotId, &rowHead);
+    if (ret != SQLITE_OK || rowHead == NULL) {
+        sqlite3_log(ret, "sharePageCmpSqlRow4Free(): invalid row.");
+        return ret;
+    }
+
+    const char *payload = (const char *)sharePageRowGetPayload(rowHead);
+    if (payload != NULL && strcmp(payload, hotSql) == 0) {
+        *isMatched = 1;
+    }
+    return SQLITE_OK;
+}
+
+void sharePageUpdate4DeleteRow(SBlkPage *page, SBlkRowHead *rowHead)
+{
+    SBlkPgHead *page_hd = &page->head;
+    rowHead->state = SBLKR_STATE_DELETE;
+    page_hd->freeSize += (rowHead->len + sizeof(SBlkRowAddr));
+}
+
+u32 sharePageGetFreeSize(SBlkPage *page)
+{
+    return page->head.freeSize;
+}
+
+int sharePageCheckRowVersion(SBlkRowHead *rowHead, QCacheVersion *ver)
+{
+    if (rowHead->ver.schemaCookie != ver->schemaCookie || rowHead->ver.changeCounter != ver->changeCounter ||
+        rowHead->ver.walSalt1 != ver->walSalt1 || rowHead->ver.walSalt2 != ver->walSalt2) {
+        return SQLITE_MISMATCH;
+    }
+
+    return SQLITE_OK;
+}
+
+/*
+** Delete a row of the specified type. The slotId must refer to an SQL row.
+**
+** If type is SBLKR_TYPE_SQL: delete both the SQL row and its result set row.
+** If type is SBLKR_TYPE_DATA: delete only the result set row for the slotId.
+*/
+int sharePageDeleteRow4Free(SBlkPage *page, SBlkRowType type, SBlkSlotID slotId)
+{
+    SBlkRowHead *slotIdRow = NULL;
+    int ret = sharePageFindRow4Free(page, slotId, &slotIdRow);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    sharePageUpdate4DeleteRow(page, slotIdRow);
+    if (type == SBLKR_TYPE_DATA) {
+        return SQLITE_OK;
+    }
+
+    /* Delete the Data row if specified */
+    SBlkSlotID dataSlotId = sharePageGetSqlDataSlotID(slotIdRow);
+    if (dataSlotId == SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+        return SQLITE_OK;
+    }
+
+    SBlkRowHead *dataRowHead = NULL;
+    ret = sharePageFindRow4Free(page, dataSlotId, &dataRowHead);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    /* Always delete the data row regardless of sql or data type */
+    sharePageUpdate4DeleteRow(page, dataRowHead);
+    return SQLITE_OK;
+}
+
+int sharePageDeleteRow4FreeCrc32(SBlkPage *page, SBlkRowType type, SBlkSlotID slotId)
+{
+    int ret = sharePageDeleteRow4Free(page, type, slotId);
+    sharePageSetCrc32(page);
+    msync(page, page->head.totalSize, MS_SYNC);
+    return ret;
+}
+
+int sharePageSqlRowUpdate4Free(SBlkPage *page, SBlkSlotID sqlRowSlotId, SBlkSlotID dataSlotId)
+{
+    SBlkRowHead *sqlRowHead = NULL;
+    int ret = sharePageFindRow4Free(page, sqlRowSlotId, &sqlRowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageSqlRowUpdate4Free(): find row.");
+        return ret;
+    }
+
+    if (sqlRowHead->type != SBLKR_TYPE_SQL) {
+        sqlite3_log(SQLITE_MISMATCH, "sharePageSqlRowUpdate4Free(): type misMatch.");
+        return SQLITE_MISMATCH;
+    }
+
+    sharePageSetSqlDataSlotID(sqlRowHead, dataSlotId);
+    return SQLITE_OK;
+}
+
+int sharePageSqlRowUpdate4FreeCrc32(SBlkPage *page, SBlkSlotID sqlRowSlotId, SBlkSlotID dataSlotId)
+{
+    int ret = sharePageSqlRowUpdate4Free(page, sqlRowSlotId, dataSlotId);
+    sharePageSetCrc32(page);
+    msync(page, page->head.totalSize, MS_SYNC);
+    return ret;
+}
+
+int sharePageCopyRowData4Free(SBlkPage *page, SBlkSlotID dataSlotId, QCacheVersion *ver, u8 **dstBuf, u32 *dstBufLen)
+{
+    SBlkRowHead *dataRowHead = NULL;
+    int ret = sharePageFindRow4Free(page, dataSlotId, &dataRowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageCopyRowData4Free(): find row.");
+        return ret;
+    }
+
+    ret = sharePageCheckRowVersion(dataRowHead, ver);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageCopyRowData4Free(): Data cache version too old.");
+        return ret;
+    }
+
+    u32 payloadLen = sharePageRowGetPayloadLen(dataRowHead);
+    u8 *tmpBuf = (u8 *)sqlite3_malloc(payloadLen);
+    if (tmpBuf == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "sharePageCopyRowData4Free(): alloc dst buffer.");
+        return SQLITE_NOMEM;
+    }
+
+    u8 *payload = sharePageRowGetPayload(dataRowHead);
+    memcpy(tmpBuf, payload, payloadLen);
+    *dstBuf = tmpBuf;
+    *dstBufLen = payloadLen;
+    return SQLITE_OK;
+}
+
+int sharePageCopyDataLen4Free(SBlkPage *page, SBlkSlotID dataSlotId, QCacheVersion *ver, u32 *dstBufLen)
+{
+    *dstBufLen = 0;
+    SBlkRowHead *dataRowHead = NULL;
+    int ret = sharePageFindRow4Free(page, dataSlotId, &dataRowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageCopyDataLen4Free(): find row.");
+        return ret;
+    }
+
+    ret = sharePageCheckRowVersion(dataRowHead, ver);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageCopyDataLen4Free(): check data row version.");
+        return ret;
+    }
+
+    u32 payloadLen = sharePageRowGetPayloadLen(dataRowHead);
+    *dstBufLen = payloadLen;
+    return SQLITE_OK;
+}
+
+int sharePageGetRawRowLen4Free(SBlkPage *page, SBlkSlotID slotId, u32 *dstBufLen)
+{
+    SBlkRowHead *rowHead = NULL;
+    int ret = sharePageFindRow4Free(page, slotId, &rowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageGetRawRowLen4Free(): find row.");
+        return ret;
+    }
+
+    *dstBufLen = rowHead->len;
+    return SQLITE_OK;
+}
+
+int sharePageGetRawRowVer4Free(SBlkPage *page, SBlkSlotID slotId, QCacheVersion *dstVer)
+{
+    SBlkRowHead *rowHead = NULL;
+    int ret = sharePageFindRow4Free(page, slotId, &rowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sharePageGetRawRowVer4Free(): find row.");
+        return ret;
+    }
+
+    *dstVer = rowHead->ver;
+    return SQLITE_OK;
+}
+
+void sharePageDeleteAnyRow4Free(SBlkPage *page)
+{
+    SBlkPgHead *pg_head = &page->head;
+    for (u32 slotId = 0; slotId < pg_head->slotCnt; slotId++) {
+        SBlkRowHead *rowHead = NULL;
+        int ret = sharePageFindRow4Free(page, slotId, &rowHead);
+        if (ret != SQLITE_OK) {
+            continue;
+        }
+
+        sharePageUpdate4DeleteRow(page, rowHead);
+    }
+}
+
+void sharePageDumpInfo4Free(SBlkPage *page)
+{
+    const char *pNew = "New Created";
+    const char *pFile = "File Restored";
+    SBlkPgHead *pg_head = &page->head;
+    qCacheDebugAppend("------Dump page info------\n");
+    qCacheDebugAppend("checksum     : %u\n", page->checksum);
+    if (page->restoreMode) {
+        qCacheDebugAppend("restoreMode  : %s\n", pFile);
+    } else {
+        qCacheDebugAppend("restoreMode  : %s\n", pNew);
+    }
+    qCacheDebugAppend("version      : %d\n", pg_head->version);
+    qCacheDebugAppend("startOffset  : %u\n", pg_head->startOffset);
+    qCacheDebugAppend("tailOffset   : %u\n", pg_head->tailOffset);
+    qCacheDebugAppend("beginPos     : %u\n", pg_head->beginPos);
+    qCacheDebugAppend("endPos       : %u\n", pg_head->endPos);
+    qCacheDebugAppend("totalSize    : %u(B)\n", pg_head->totalSize);
+    qCacheDebugAppend("freeSize     : %u(B)\n", pg_head->freeSize);
+    qCacheDebugAppend("maxRowSize   : %u(B)\n", pg_head->maxRowSize);
+    qCacheDebugAppend("slotCnt      : %u\n", pg_head->slotCnt);
+}
+
+// ================================================================================================================//
+
+static QHashNode *qHashTableGetBucketFirst(QHashTable *hTable, const u32 bucketIdx)
+{
+    return hTable->bucket[bucketIdx];
+}
+
+static void qHashTableSetBucketFirst(QHashTable *hTable, u32 bucketIdx, QHashNode *node)
+{
+    if (hTable && bucketIdx < hTable->bucketCnt) {
+        hTable->bucket[bucketIdx] = node;
+    }
+}
+
+void qHashTableInitBasic(QHashTable *hTable, int fd, u32 initMemSize, u32 maxMemSize)
+{
+    hTable->lockFd = fd;
+    hTable->bucketCnt = QHASH_BUCKET_SIZE;
+    hTable->maskCode = QHASH_BUCKET_SIZE - 1;
+    hTable->calcMagic = QHASH_CALC_MAGIC;
+    hTable->curMemSize = initMemSize;
+    hTable->maxMemSize = maxMemSize;
+    hTable->malloc = sqlite3_malloc;
+    hTable->free = sqlite3_free;
+    hTable->lockPage = sharePageWRLock;
+    hTable->unLockPage = sharePageUnLock;
+    hTable->expandPage4Free = sharePageExpand4Free;
+    hTable->compareRow4Free = sharePageCmpSqlRow4Free;
+    hTable->insertRow4Free = sharePageInsertRow4FreeCrc32;
+    hTable->deleteRow4Free = sharePageDeleteRow4FreeCrc32;
+    hTable->updateSqlRow4Free = sharePageSqlRowUpdate4FreeCrc32;
+    hTable->copyRowData4Free = sharePageCopyRowData4Free;
+    hTable->compressPage4Free = sharePageCompress4Free;
+}
+
+/*
+** Initialize the QHashTable structure.
+*/
+int qHashTableInit(QHashTable *hTable, int fd, u32 initMemSize, u32 maxMemSize)
+{
+    memset(hTable, 0, sizeof(QHashTable));
+    u8 *mapAddr = (u8 *)mmap(NULL, initMemSize, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    if (mapAddr == MAP_FAILED) {
+        sqlite3_log(SQLITE_CANTOPEN, "qHashTableInit(): mmap failed, %s", strerror(errno));
+        return SQLITE_CANTOPEN;
+    }
+
+    u32 maxRowSize = maxMemSize >> 1;
+    int ret = sharePageInit(mapAddr, initMemSize, maxRowSize, &hTable->page);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInit(): sharePageInit failed.");
+        munmap(mapAddr, initMemSize);
+        return ret;
+    }
+
+    qHashTableInitBasic(hTable, fd, initMemSize, maxMemSize);
+
+    return SQLITE_OK;
+}
+
+void qHashTableFreeBuckets4Free(QHashTable *hTable)
+{
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode **ppNode = &hTable->bucket[i];
+        while (*ppNode != NULL) {
+            QHashNode *pNode = *ppNode;
+            *ppNode = pNode->next;
+            hTable->free(pNode);
+        }
+    }
+}
+
+void qHashTableDestroy4Free(QHashTable *hTable)
+{
+    if (hTable->page) {
+        munmap(hTable->page, hTable->curMemSize);
+        hTable->page = NULL;
+    }
+    qHashTableFreeBuckets4Free(hTable);
+}
+
+int qHashTableAttach4SingleFree(QHashTable *hTable, int fd, u32 attachSize, u32 maxMemSize, u32 *newPageSize)
+{
+    /* Map to shared memory */
+    u8 *mapAddr = (u8 *)mmap(NULL, attachSize, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    if (mapAddr == MAP_FAILED) {
+        sqlite3_log(SQLITE_CANTOPEN, "qHashTableAttach4Free(): mmap failed, %s", strerror(errno));
+        return SQLITE_CANTOPEN;
+    }
+
+    int ret = sharePageAttach(mapAddr, attachSize, newPageSize, &hTable->page);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableAttach4Free(): sharePageAttach failed.");
+        munmap(mapAddr, attachSize);
+        hTable->page = NULL;
+        return ret;
+    }
+
+    if (attachSize > maxMemSize) {
+        sqlite3_log(SQLITE_TOOBIG, "qHashTableAttach4Free(): old page too big.");
+        munmap(mapAddr, attachSize);
+        hTable->page = NULL;
+        return SQLITE_TOOBIG;
+    }
+
+    qHashTableInitBasic(hTable, fd, attachSize, maxMemSize);
+    return SQLITE_OK;
+}
+
+int qHashTableAttach4MultiInstFree(QHashTable *hTable, int fd, u32 attachSize, u32 maxMemSize, u32 *newPageSize)
+{
+    /* Map to shared memory */
+    u8 *mapAddr = (u8 *)mmap(NULL, attachSize, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    if (mapAddr == MAP_FAILED) {
+        sqlite3_log(SQLITE_CANTOPEN, "qHashTableAttach4MultiInstFree(): mmap failed, %s", strerror(errno));
+        return SQLITE_CANTOPEN;
+    }
+
+    SBlkPage *attachPage = (SBlkPage *)mapAddr;
+    u32 curPgSize = sharePageGetTotalSize(attachPage);
+    if (curPgSize != attachSize) {
+        sqlite3_log(SQLITE_CORRUPT, "qHashTableAttach4MultiInstFree(): page size misMatch.");
+        munmap(mapAddr, attachSize);
+        *newPageSize = curPgSize;
+        return SQLITE_CORRUPT;
+    }
+
+    hTable->page = attachPage;
+    qHashTableInitBasic(hTable, fd, attachSize, maxMemSize);
+    return SQLITE_OK;
+}
+
+int qHashTableAttach4Free(
+    QHashTable *hTable, int fd, u32 attachSize, u32 maxMemSize, u8 isMultiInst, u32 *newPageSize)
+{
+    if (isMultiInst) {
+        return qHashTableAttach4MultiInstFree(hTable, fd, attachSize, maxMemSize, newPageSize);
+    }
+
+    return qHashTableAttach4SingleFree(hTable, fd, attachSize, maxMemSize, newPageSize);
+}
+
+static u32 qHashTableStr2BucketId(QHashTable *hTable, const char *str)
+{
+    u32 c;
+    u32 hash = hTable->calcMagic;
+    while ((c = *str++)) {
+        hash = ((hash << 5) + hash) + c;
+    }
+
+    return hash & hTable->maskCode;
+}
+
+int qHashTableInsert4Free(QHashTable *hTable, u32 bucketIdx, SBlkSlotID newSlotId)
+{
+    QHashNode *newNode = hTable->malloc(sizeof(QHashNode));
+    if (newNode == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "QCacheInsertSql(): out of memory.");
+        return SQLITE_NOMEM;
+    }
+
+    newNode->sqlSlotId = newSlotId;
+    newNode->dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    newNode->hitSqlCnt = 0;
+    newNode->hitDataCnt = 0;
+    newNode->next = hTable->bucket[bucketIdx];
+    hTable->bucket[bucketIdx] = newNode;
+
+    return SQLITE_OK;
+}
+
+int qHashTableInsertPair(QHashTable *hTable, u32 bucketIdx, SBlkSlotID sqlSlotId, SBlkSlotID dataSlotId)
+{
+    /* Allocate and initialize a new node */
+    QHashNode *newNode = hTable->malloc(sizeof(QHashNode));
+    if (newNode == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "qHashTableInsertPair(): out of memory.");
+        return SQLITE_NOMEM;
+    }
+
+    newNode->sqlSlotId = sqlSlotId;
+    newNode->dataSlotId = dataSlotId;
+    newNode->hitSqlCnt = 0;
+    newNode->hitDataCnt = 0;
+    newNode->next = hTable->bucket[bucketIdx];
+    hTable->bucket[bucketIdx] = newNode;
+
+    return SQLITE_OK;
+}
+
+int qHashTableDelete4Free(QHashTable *hTable, u32 bucketIdx, QHashNode *toDelete)
+{
+    QHashNode **ppNode = &hTable->bucket[bucketIdx];
+    while (*ppNode != NULL) {
+        QHashNode *pNode = *ppNode;
+        if (pNode == toDelete) {
+            *ppNode = pNode->next;
+            hTable->free(pNode);
+            break;
+        }
+        ppNode = &pNode->next;
+    }
+
+    return SQLITE_OK;
+}
+
+int qHashTableReMmap4Free(QHashTable *hTable)
+{
+    int ret = sharePageHeadCheck(hTable->page);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableReMmap4Free(): check head failed.");
+        return ret;
+    }
+
+    u32 curPgSize = sharePageGetTotalSize(hTable->page);
+    if (hTable->curMemSize == curPgSize) {
+        return SQLITE_OK;
+    }
+
+    // munmap(old_page)
+    munmap(hTable->page, hTable->curMemSize);
+
+    /* Remap to shared memory */
+    u8 *mapAddr = (u8 *)mmap(NULL, curPgSize, PROT_READ | PROT_WRITE, MAP_SHARED, hTable->lockFd, 0);
+    if (mapAddr == MAP_FAILED) {
+        sqlite3_log(SQLITE_CANTOPEN, "qHashTableReMmap4Free(): mmap failed, %s", strerror(errno));
+        hTable->page = NULL;
+        hTable->curMemSize = 0;
+        return SQLITE_CANTOPEN;
+    }
+
+    hTable->page = (SBlkPage *)mapAddr;
+    hTable->curMemSize = curPgSize;
+
+    return SQLITE_OK;
+}
+
+int qHashTableFindSql4Free(QHashTable *hTable, const char *key, u32 bucketIdx, QHashNode **found)
+{
+    int ret = SQLITE_OK;
+    u8 isMatched = 0;
+    QHashNode *prevNode = NULL;
+    QHashNode *node = qHashTableGetBucketFirst(hTable, bucketIdx);
+    while (node) {
+        QHashNode *nextNode = node->next;
+        ret = hTable->compareRow4Free(hTable->page, node->sqlSlotId, key, &isMatched);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableFindSql4Free(): invalid sql row.");
+            hTable->free(node);
+            if (prevNode) {
+                prevNode->next = nextNode;
+            } else {
+                qHashTableSetBucketFirst(hTable, bucketIdx, nextNode);
+            }
+            node = nextNode;
+            ret = SQLITE_OK;
+            continue;
+        }
+
+        if (isMatched) {
+            *found = node;
+            break;
+        }
+        prevNode = node;
+        node = nextNode;
+    }
+
+    return ret;
+}
+
+int qHashTableRebuild4Free(QHashTable *hTable)
+{
+    SBlkPage *page = hTable->page;
+    for (SBlkSlotID slotId = 0; slotId < page->head.slotCnt; slotId++) {
+        SBlkRowHead *rowHead = NULL;
+        int ret = sharePageFindRow4Free(page, slotId, &rowHead);
+        if (rowHead && rowHead->state != SBLKR_STATE_USED) {
+            continue;
+        }
+
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableRebuild4Free(): find row %u failed.", slotId);
+            return ret;
+        }
+
+        /* Process only valid SQL rows */
+        if (rowHead->type != SBLKR_TYPE_SQL || rowHead->state != SBLKR_STATE_USED) {
+            continue;
+        }
+
+        /* Retrieve SQL payload */
+        const char *sqlPayload = (const char *)sharePageRowGetPayload(rowHead);
+        u32 bucketIdx = qHashTableStr2BucketId(hTable, sqlPayload);
+
+        /* Get associated data slot ID */
+        SBlkSlotID dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+        dataSlotId = sharePageGetSqlDataSlotID(rowHead);
+        /* Validate the corresponding data slot if present */
+        if (dataSlotId != SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+            SBlkRowHead *dataRowHead = NULL;
+            ret = sharePageFindRow4Free(page, dataSlotId, &dataRowHead);
+            if (ret != SQLITE_OK || dataRowHead->type != SBLKR_TYPE_DATA ||
+                dataRowHead->state != SBLKR_STATE_USED) {
+                sqlite3_log(ret, "qHashTableRebuild4Free(): find row %u failed.", dataSlotId);
+                dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+                sharePageSetSqlDataSlotID(rowHead, dataSlotId);
+            }
+        }
+
+        QHashNode *found = NULL;
+        ret = qHashTableFindSql4Free(hTable, sqlPayload, bucketIdx, &found);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableRebuild4Free(): find node.");
+            return ret;
+        }
+
+        if (found) {
+            /* Duplicate entry exists, remove redundant row */
+            ret = hTable->deleteRow4Free(hTable->page, SBLKR_TYPE_SQL, slotId);
+            if (ret != SQLITE_OK) {
+                sqlite3_log(ret, "qHashTableRebuild4Free(): delete dup row.");
+                return ret;
+            }
+        } else {
+            ret = qHashTableInsertPair(hTable, bucketIdx, slotId, dataSlotId);
+            if (ret != SQLITE_OK) {
+                sqlite3_log(ret, "qHashTableRebuild4Free(): insert safe.");
+                return ret;
+            }
+        }
+    }
+
+    return SQLITE_OK;
+}
+
+int qHashTableReSize4Free(QHashTable *hTable, u32 newTotalSize)
+{
+    void *oldAddr = hTable->page;
+    u32 oldSize = hTable->curMemSize;
+    u32 pageSize = sysconf(_SC_PAGESIZE);
+    u32 alignedNewSize = ((newTotalSize + pageSize - 1) / pageSize) * pageSize;
+
+    /* Remap to larger shared memory region */
+    u8 *newAddr = (u8 *)mremap(oldAddr, oldSize, alignedNewSize, MREMAP_MAYMOVE);
+    if (newAddr == MAP_FAILED) {
+        int savedErrno = errno;
+        sqlite3_log(SQLITE_WARNING, "qHashTableReSize4Free(): mremap failed (errno=%d), trying fallback method",
+            savedErrno);
+        newAddr = mmap(NULL, alignedNewSize, PROT_READ | PROT_WRITE, MAP_SHARED, hTable->lockFd, 0);
+        if (newAddr == MAP_FAILED) {
+            sqlite3_log(SQLITE_CANTOPEN, "qHashTableReSize4Free(): fallback mmap also failed, errno=%d (%s)",
+                savedErrno, strerror(savedErrno));
+            return SQLITE_NOMEM;
+        }
+        memcpy(newAddr, oldAddr, oldSize);
+        memset((u8 *)newAddr + oldSize, 0, alignedNewSize - oldSize);
+        int ret = munmap(oldAddr, oldSize);
+        if (ret != 0) {
+            sqlite3_log(SQLITE_WARNING, "qHashTableReSize4Free(): munmap failed for old mapping.");
+        }
+    } else if (alignedNewSize > oldSize) {
+        memset((u8 *)newAddr + oldSize, 0, alignedNewSize - oldSize);
+    }
+
+    hTable->page = hTable->expandPage4Free(newAddr, newTotalSize);
+    hTable->curMemSize = newTotalSize;
+
+    return SQLITE_OK;
+}
+
+void qHashTableResetHitCount(QHashTable *hTable)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_RLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableResetHitCount(): write lock.");
+        return;
+    }
+
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode *pNode = hTable->bucket[i];
+        while (pNode != NULL) {
+            pNode->hitSqlCnt = 0;
+            pNode = pNode->next;
+        }
+    }
+
+    hTable->unLockPage(hTable->lockFd);
+}
+
+int qHashTableDeleteAllNodeData(QHashTable *hTable)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_WLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteAllNodeData(): write lock.");
+        return ret;
+    }
+
+    ret = qHashTableReMmap4Free(hTable);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteAllNodeData(): qHashTableReMmap4Free.");
+        hTable->unLockPage(hTable->lockFd);
+        return ret;
+    }
+    sharePageDeleteAnyRow4Free(hTable->page);
+    qHashTableFreeBuckets4Free(hTable);
+
+    hTable->unLockPage(hTable->lockFd);
+
+    return SQLITE_OK;
+}
+
+int qHashTableDeleteNodeData(QHashTable *hTable, QHashNode *minHitNode)
+{
+    int ret = SQLITE_OK;
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode *pNode = hTable->bucket[i];
+        while (pNode != NULL) {
+            if (pNode->sqlSlotId != minHitNode->sqlSlotId || pNode->dataSlotId != minHitNode->dataSlotId) {
+                pNode = pNode->next;
+                continue;
+            }
+
+            (void)hTable->deleteRow4Free(hTable->page, SBLKR_TYPE_DATA, pNode->dataSlotId);
+            pNode->hitDataCnt = 0;
+            pNode->dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+            ret = hTable->updateSqlRow4Free(hTable->page, pNode->sqlSlotId, pNode->dataSlotId);
+            if (ret != SQLITE_OK) {
+                sqlite3_log(ret, "qHashTableDeleteNodeData(): update sql row.");
+            }
+            return SQLITE_OK;
+        }
+    }
+
+    return ret;
+}
+
+int qHashTableDeleteSql(QHashTable *hTable, const char *hotSql)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_WLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteSql(): write lock.");
+        goto EXIT_RET0;
+    }
+
+    ret = qHashTableReMmap4Free(hTable);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteSql(): qHashTableReMmap4Free.");
+        goto EXIT_RET1;
+    }
+
+    QHashNode *found = NULL;
+    u32 bucketIdx = qHashTableStr2BucketId(hTable, hotSql);
+    ret = qHashTableFindSql4Free(hTable, hotSql, bucketIdx, &found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteSql(): find node.");
+        goto EXIT_RET1;
+    }
+
+    if (!found) {
+        sqlite3_log(SQLITE_OK, "qHashTableDeleteSql(): sql not exist, %s.", hotSql);
+        goto EXIT_RET1;
+    }
+
+    ret = hTable->deleteRow4Free(hTable->page, SBLKR_TYPE_SQL, found->sqlSlotId);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteSql(): delete sql row.");
+        goto EXIT_RET1;
+    }
+
+    ret = qHashTableDelete4Free(hTable, bucketIdx, found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableDeleteSql(): delete hashNode.");
+        goto EXIT_RET1;
+    }
+
+EXIT_RET1:
+    hTable->unLockPage(hTable->lockFd);
+EXIT_RET0:
+    return ret;
+}
+
+int qHashTableCalcExpandSize(SBlkPage *page, u32 maxMemSize, u32 needSize, u32 *outNewTotalSize)
+{
+    u32 stepSize = SHARED_BLOCK_PAGE_STEP_SIZE;
+    u32 curTotalSize = sharePageGetTotalSize(page);
+    u32 curFreeSize = sharePageGetFreeSize(page);
+    u32 newTotalSize = curTotalSize;
+
+    if (newTotalSize >= maxMemSize) {
+        return SQLITE_NOMEM;
+    }
+
+    while (newTotalSize < maxMemSize) {
+        u32 add = 0;
+
+        if (newTotalSize + stepSize < maxMemSize) {
+            add = stepSize;
+        } else {
+            add = maxMemSize - newTotalSize;
+        }
+
+        newTotalSize += add;
+        curFreeSize += add;
+
+        if (curFreeSize >= needSize) {
+            break;
+        }
+    }
+
+    if (curFreeSize < needSize) {
+        return SQLITE_NOMEM;
+    }
+
+    *outNewTotalSize = newTotalSize;
+    return SQLITE_OK;
+}
+
+int qHashTableCompressRebuild4Free(QHashTable *hTable, int byFast)
+{
+    int needRebuild = 0;
+    int ret = hTable->compressPage4Free(hTable->page, &needRebuild);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableCompressRebuild4Free(): compressPage4Free failed.");
+        return ret;
+    }
+
+    if (byFast && !needRebuild) {
+        return SQLITE_OK;
+    }
+
+    qHashTableFreeBuckets4Free(hTable);
+    return qHashTableRebuild4Free(hTable);
+}
+
+/*
+** Insert a row into the QHashTable page.
+** Attempt direct insertion first; if out of memory, expand the page and retry.
+**
+** hTable:     Hash table handle.
+** type:       Row type (SQL or data).
+** data:       Payload data to insert.
+** dataLen:    Length of payload data.
+** newSlotId:  Output: Assigned slot ID for the new row.
+**
+** Return SQLITE_OK on success, error code otherwise.
+*/
+int qHashTableInsertRow4Free(
+    QHashTable *hTable,
+    SBlkRowType type,
+    QCacheVersion *ver,
+    u8 *data,
+    u32 dataLen,
+    SBlkSlotID *newSlotId)
+{
+    /* Attempt direct row insertion first */
+    int ret = hTable->insertRow4Free(hTable->page, type, ver, data, dataLen, newSlotId);
+    if (ret == SQLITE_OK) {
+        return SQLITE_OK;
+    }
+
+    /* Return error if not out-of-memory */
+    if (ret != SQLITE_NOMEM) {
+        sqlite3_log(ret, "qHashTableInsertRow4Free(): insert row.");
+        return ret;
+    }
+
+    /* Calculate new expanded size */
+    u32 newTotalSize = 0;
+    u32 needSize = sharePageGetRowSize(type, dataLen);
+    ret = qHashTableCalcExpandSize(hTable->page, hTable->maxMemSize, needSize, &newTotalSize);
+    if (ret == SQLITE_OK) {
+        ret = qHashTableReSize4Free(hTable, newTotalSize);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableInsertRow4Free(): qHashTableReSize4Free failed.");
+            return ret;
+        }
+        return hTable->insertRow4Free(hTable->page, type, ver, data, dataLen, newSlotId);
+    }
+
+    ret = qHashTableCompressRebuild4Free(hTable, 1);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertRow4Free(): qHashTableCompressRebuild4Free failed.");
+        return ret;
+    }
+
+    return hTable->insertRow4Free(hTable->page, type, ver, data, dataLen, newSlotId);
+}
+
+int qHashTableInsertSql(QHashTable *hTable, const char *hotSql)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_WLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertSql(): write lock.");
+        goto EXIT_RET0;
+    }
+
+    ret = qHashTableReMmap4Free(hTable);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertSql(): qHashTableReMmap4Free.");
+        goto EXIT_RET1;
+    }
+
+    QHashNode *found = NULL;
+    u32 bucketIdx = qHashTableStr2BucketId(hTable, hotSql);
+    ret = qHashTableFindSql4Free(hTable, hotSql, bucketIdx, &found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertSql(): find node.");
+        goto EXIT_RET1;
+    }
+
+    if (found) {
+        sqlite3_log(SQLITE_OK, "qHashTableInsertSql(): sql exist, %s.", hotSql);
+        goto EXIT_RET1;
+    }
+
+    QCacheVersion version = {0};
+    SBlkSlotID newSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    ret = qHashTableInsertRow4Free(hTable, SBLKR_TYPE_SQL, &version, (u8 *)hotSql, strlen(hotSql) + 1, &newSlotId);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertSql(): insert sql row.");
+        goto EXIT_RET1;
+    }
+
+    ret = qHashTableInsert4Free(hTable, bucketIdx, newSlotId);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableInsertSql(): insert hashNode.");
+        goto EXIT_RET1;
+    }
+
+EXIT_RET1:
+    hTable->unLockPage(hTable->lockFd);
+EXIT_RET0:
+    return ret;
+}
+
+int qHashTableFindMinHitNode(QHashTable *hTable, QHashNode *target, QHashNode *minNode)
+{
+    QHashNode tmpNode = (QHashNode){0};
+    tmpNode.hitSqlCnt = target->hitSqlCnt;
+    tmpNode.dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode *pNode = hTable->bucket[i];
+        while (pNode != NULL) {
+            if (pNode->dataSlotId == SHARED_BLOCK_PAGE_INVALID_SLOTID || pNode->hitSqlCnt >= tmpNode.hitSqlCnt) {
+                pNode = pNode->next;
+                continue;
+            }
+
+            if (tmpNode.dataSlotId == SHARED_BLOCK_PAGE_INVALID_SLOTID || pNode->hitSqlCnt < tmpNode.hitSqlCnt) {
+                tmpNode = *pNode;
+            }
+            pNode = pNode->next;
+        }
+    }
+
+    if (tmpNode.dataSlotId == SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+        return SQLITE_NOTFOUND;
+    }
+
+    *minNode = tmpNode;
+    return SQLITE_OK;
+}
+
+int qHashTableDropLFU4Free(QHashTable *hTable, QHashNode *found, u32 dataLen)
+{
+    u32 totalFreeSize = sharePageGetFreeSize(hTable->page);
+    u32 rowNeedSize = sharePageGetRowSize(SBLKR_TYPE_DATA, dataLen) + sizeof(SBlkRowAddr);
+    if (totalFreeSize >= rowNeedSize) {
+        return SQLITE_OK;
+    }
+
+    int ret = SQLITE_OK;
+    QHashNode minHitNode = (QHashNode){0};
+    do {
+        ret = qHashTableFindMinHitNode(hTable, found, &minHitNode);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableDropLFU4Free(): find minHitNode.");
+            return ret;
+        }
+
+        ret = qHashTableDeleteNodeData(hTable, &minHitNode);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableDropLFU4Free(): delete data row.");
+            return ret;
+        }
+
+        totalFreeSize = sharePageGetFreeSize(hTable->page);
+    } while (totalFreeSize < rowNeedSize);
+
+    return SQLITE_OK;
+}
+
+int qHashTableUpdateDataStay(QHashTable *hTable, u8 *data, u32 dataLen, QCacheVersion *ver, SBlkSlotID dataSlotId)
+{
+    SBlkRowHead *rowHead = NULL;
+    int ret = sharePageFindRow4Free(hTable->page, dataSlotId, &rowHead);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateDataStay(): find data row %u.", dataSlotId);
+        return ret;
+    }
+
+    u32 payloadLen = sharePageRowGetPayloadLen(rowHead);
+    if (dataLen > payloadLen) {
+        sqlite3_log(SQLITE_TOOBIG, "qHashTableUpdateDataStay(): current payloadLen %u, new payloadLen %u.", payloadLen,
+            dataLen);
+        return SQLITE_TOOBIG;
+    }
+
+    u8 *rowPayload = sharePageRowGetPayload(rowHead);
+    memset(rowPayload, 0, payloadLen);
+    memcpy(rowPayload, data, dataLen);
+    rowHead->ver = *ver;
+    sqlite3_log(SQLITE_OK, "qHashTableUpdateDataStay(): update data in row %u, old payloadLen %u, new payloadLen %u.",
+        dataSlotId, payloadLen, dataLen);
+
+    return SQLITE_OK;
+}
+
+int qHashTableUpdateSqlData(QHashTable *hTable, const char *hotSql, u8 *data, u32 dataLen, QCacheVersion *ver)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_WLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): write lock.");
+        goto EXIT_RET0;
+    }
+
+    ret = qHashTableReMmap4Free(hTable);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): qHashTableReMmap4Free.");
+        goto EXIT_RET1;
+    }
+
+    QHashNode *found = NULL;
+    u32 bucketIdx = qHashTableStr2BucketId(hTable, hotSql);
+    ret = qHashTableFindSql4Free(hTable, hotSql, bucketIdx, &found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): find node.");
+        goto EXIT_RET1;
+    }
+
+    if (!found) {
+        sqlite3_log(SQLITE_OK, "qHashTableUpdateSqlData(): sql not exist, %s.", hotSql);
+        goto EXIT_RET1;
+    }
+
+    if (found->dataSlotId != SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+        ret = qHashTableUpdateDataStay(hTable, data, dataLen, ver, found->dataSlotId);
+        if (ret == SQLITE_OK) {
+            found->hitDataCnt = 0;
+            goto EXIT_RET1;
+        }
+        (void)hTable->deleteRow4Free(hTable->page, SBLKR_TYPE_DATA, found->dataSlotId);
+        found->hitDataCnt = 0;
+        found->dataSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    }
+
+    SBlkSlotID newSlotId = SHARED_BLOCK_PAGE_INVALID_SLOTID;
+    ret = qHashTableInsertRow4Free(hTable, SBLKR_TYPE_DATA, ver, data, dataLen, &newSlotId);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): insert data row.");
+        /* Check if sufficient space is available.
+         ** If not, evict the least frequently used (LFU) cache entry.
+         ** Return an error if still insufficient space after eviction.
+         */
+        ret = qHashTableDropLFU4Free(hTable, found, dataLen);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableUpdateSqlData(): swap LFU rows.");
+            goto EXIT_RET1;
+        }
+
+        ret = qHashTableInsertRow4Free(hTable, SBLKR_TYPE_DATA, ver, data, dataLen, &newSlotId);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "qHashTableUpdateSqlData(): insert data row after swap LFU rows.");
+            goto EXIT_RET1;
+        }
+    }
+
+    ret = qHashTableFindSql4Free(hTable, hotSql, bucketIdx, &found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): find node after swap LFU rows.");
+        goto EXIT_RET1;
+    }
+
+    ret = hTable->updateSqlRow4Free(hTable->page, found->sqlSlotId, newSlotId);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableUpdateSqlData(): update sql row.");
+        (void)hTable->deleteRow4Free(hTable->page, SBLKR_TYPE_DATA, newSlotId);
+        goto EXIT_RET1;
+    }
+    found->hitDataCnt = 0;
+    found->dataSlotId = newSlotId;
+
+EXIT_RET1:
+    hTable->unLockPage(hTable->lockFd);
+EXIT_RET0:
+    return ret;
+}
+
+int qHashTableIsHotSql(
+    QHashTable *hTable,
+    const char *hotSql,
+    QCacheVersion *ver,
+    u8 *isHot,
+    u8 **dstBuf,
+    u32 *dstBufLen)
+{
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_RLOCK);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableIsHotSql(): read lock.");
+        goto EXIT_RET0;
+    }
+
+    ret = qHashTableReMmap4Free(hTable);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableIsHotSql(): qHashTableReMmap4Free.");
+        goto EXIT_RET1;
+    }
+
+    QHashNode *found = NULL;
+    u32 bucketIdx = qHashTableStr2BucketId(hTable, hotSql);
+    ret = qHashTableFindSql4Free(hTable, hotSql, bucketIdx, &found);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableIsHotSql(): find node.");
+        goto EXIT_RET1;
+    }
+
+    if (!found) {
+        goto EXIT_RET1;
+    }
+
+    *isHot = 1;
+    found->hitSqlCnt++;
+    if (found->dataSlotId == SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+        *dstBufLen = 0;
+        found->hitDataCnt = 0;
+        goto EXIT_RET1;
+    }
+
+    ret = hTable->copyRowData4Free(hTable->page, found->dataSlotId, ver, dstBuf, dstBufLen);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qHashTableIsHotSql(): copy data.");
+        found->hitDataCnt = 0;
+        goto EXIT_RET1;
+    }
+    found->hitDataCnt++;
+
+EXIT_RET1:
+    hTable->unLockPage(hTable->lockFd);
+EXIT_RET0:
+    return ret;
+}
+
+int qHashTableDumpBasic(QHashTable *hTable)
+{
+    qCacheDebugAppend("------Dump Hash Table------\n");
+    qCacheDebugAppend("bucketCnt    : %u\n", hTable->bucketCnt);
+    qCacheDebugAppend("curMemSize   : %u(B)\n", hTable->curMemSize);
+    qCacheDebugAppend("maxMemSize   : %u(B)\n", hTable->maxMemSize);
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_RLOCK);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    u32 sqlLen = 0;
+    u32 dataLen = 0;
+    QCacheVersion version = {0};
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode *pNode = hTable->bucket[i];
+        while (pNode != NULL) {
+            if (pNode->sqlSlotId != SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+                (void)sharePageGetRawRowLen4Free(hTable->page, pNode->sqlSlotId, &sqlLen);
+            }
+            if (pNode->dataSlotId != SHARED_BLOCK_PAGE_INVALID_SLOTID) {
+                (void)sharePageGetRawRowLen4Free(hTable->page, pNode->dataSlotId, &dataLen);
+                (void)sharePageGetRawRowVer4Free(hTable->page, pNode->dataSlotId, &version);
+            }
+            qCacheDebugAppend("hashNode[%4u, %5u, %10u, %10u][%2u, %5u], hitSqlCnt: %5u, hitDataCnt: %5u,"
+                "hotSqlLen: %6u, hotDataLen: %6u\n",
+                version.schemaCookie,
+                version.changeCounter,
+                version.walSalt1,
+                version.walSalt2,
+                pNode->sqlSlotId,
+                pNode->dataSlotId,
+                pNode->hitSqlCnt,
+                pNode->hitDataCnt,
+                sqlLen,
+                dataLen);
+            sqlLen = 0;
+            dataLen = 0;
+            pNode = pNode->next;
+        }
+    }
+
+    sharePageDumpInfo4Free(hTable->page);
+    hTable->unLockPage(hTable->lockFd);
+
+    return SQLITE_OK;
+}
+
+int qHashTableDumpSQL(QHashTable *hTable)
+{
+    qCacheDebugAppend("curMemSize   : %u(B)\n", hTable->curMemSize);
+    qCacheDebugAppend("maxMemSize   : %u(B)\n", hTable->maxMemSize);
+    int ret = hTable->lockPage(hTable->lockFd, QCACHE_PAGE_RLOCK);
+    if (ret != SQLITE_OK) {
+        return ret;
+    }
+
+    for (u32 i = 0; i < hTable->bucketCnt; i++) {
+        QHashNode *pNode = hTable->bucket[i];
+        while (pNode != NULL) {
+            SBlkRowHead *rowHead = NULL;
+            ret = sharePageFindRow4Free(hTable->page, pNode->sqlSlotId, &rowHead);
+            if (ret != SQLITE_OK) {
+                sqlite3_log(ret, "qHashTableDumpSQL: find sql row.");
+                pNode = pNode->next;
+                continue;
+            }
+            if (rowHead->type != SBLKR_TYPE_SQL) {
+                sqlite3_log(ret, "qHashTableDumpSQL: invalid sql row type.");
+                pNode = pNode->next;
+                continue;
+            }
+            const char *sqlPayload = (const char *)sharePageRowGetPayload(rowHead);
+            qCacheDebugAppend("\n");
+            qCacheDebugAppend("hotSql[%u] hotSqlStr : %s\n", pNode->sqlSlotId, sqlPayload);
+            qCacheDebugAppend("hotSql[%u] hitSqlCnt : %u\n", pNode->sqlSlotId, pNode->hitSqlCnt);
+            qCacheDebugAppend("hotSql[%u] hitDataCnt: %u\n", pNode->sqlSlotId, pNode->hitDataCnt);
+            pNode = pNode->next;
+        }
+    }
+    hTable->unLockPage(hTable->lockFd);
+
+    return SQLITE_OK;
+}

+// ================================================================================================================
+
+static pthread_mutex_t g_QcacheEntryMutex = PTHREAD_MUTEX_INITIALIZER;
+static QCacheEntry *g_QcacheEntrySingleton = NULL;
+
+QCacheEntry *sqlite3QCacheGetProcessEntry(void)
+{
+    return g_QcacheEntrySingleton;
+}
+
+static void sqlite3QCacheSetProcessEntry(QCacheEntry *newEntry)
+{
+    g_QcacheEntrySingleton = newEntry;
+}
+
+static void qCacheDestroyProcessEntry(void)
+{
+    if (!g_QcacheEntrySingleton) {
+        return;
+    }
+
+    qCacheEntryDestroyInner(g_QcacheEntrySingleton);
+}
+
+static void qCacheRegProcessEntryCleanUp(void)
+{
+    atexit(qCacheDestroyProcessEntry);
+}
+
+void qCacheEntryDoRoutine(QCacheEntry *entry)
+{
+    if (!entry) {
+        return;
+    }
+
+    struct timespec startTs = entry->ts;
+    struct timespec currTs;
+    clock_gettime(CLOCK_MONOTONIC, &currTs);
+    u32 invalidLFUPeriod = entry->ttlCycle;
+    if (currTs.tv_sec - startTs.tv_sec < invalidLFUPeriod) {
+        return;
+    }
+
+    qHashTableResetHitCount(&entry->sql2Data);
+    entry->ts = currTs;
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] qcache entry Reseted hitcount.");
+#endif /* SQLITE_QUERY_CACHE_DEBUG */
+}
+
+static int buildCacheFilePath(const char *dbPath, char *cacheFilePath, size_t pathSize)
+{
+    if (!dbPath || !cacheFilePath || pathSize == 0) {
+        return SQLITE_MISUSE;
+    }
+
+    size_t dbPathLen = strlen(dbPath);
+    size_t suffixLen = strlen(CACHE_FILE_SUFFIX);
+
+    if (dbPathLen + suffixLen + 1 > pathSize) {
+        return SQLITE_MISUSE;
+    }
+
+    strcpy(cacheFilePath, dbPath);
+    strcat(cacheFilePath, CACHE_FILE_SUFFIX);
+
+    return SQLITE_OK;
+}
+
+int qCacheEntryCreateInner(QCacheEntry *entry, const char *dbPath)
+{
+    size_t dbPathLen = strlen(dbPath);
+    size_t suffixLen = strlen(CACHE_FILE_SUFFIX);
+    size_t cacheFilePathLen = dbPathLen + suffixLen + 1;
+    entry->QCacheMapFPath = (char *)sqlite3_malloc(cacheFilePathLen);
+    if (entry->QCacheMapFPath == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "qCacheEntryCreateInner(): malloc entry.");
+        return SQLITE_NOMEM;
+    }
+
+    int ret = buildCacheFilePath(dbPath, entry->QCacheMapFPath, (size_t)cacheFilePathLen);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheEntryCreateInner(): buildCacheFilePath failed.");
+        sqlite3_free(entry->QCacheMapFPath);
+        entry->QCacheMapFPath = NULL;
+        return ret;
+    }
+
+    int retIn = lstat(dbPath, &entry->dbFstat);
+    if (retIn != 0) {
+        sqlite3_log(SQLITE_IOERR, "qCacheEntryCreateInner(): lstat failed, %s", strerror(errno));
+        entry->dbFstat.st_uid = -1;
+        entry->dbFstat.st_gid = -1;
+        entry->dbFstat.st_mode = 0644;
+    }
+
+    entry->fd = -1;
+    entry->cacheFileSize = 0;
+    entry->multiInstFd = -1;
+    entry->isMultiInst = 0;
+    entry->inAccessible = 0;
+    entry->QCacheInsFlock = NULL;
+    entry->ttlCycle = QHASH_HIT_LFU_CYCLE;
+    clock_gettime(CLOCK_MONOTONIC, &entry->ts);
+
+    return SQLITE_OK;
+}
+
+int qCacheEntryHandleByType(QCacheEntry *entry, QCacheMsgType msgType, QCacheVersion *ver)
+{
+    int ret = SQLITE_OK;
+    switch (msgType) {
+        case QCACHE_MSG_EXIT:
+            ret = qCacheEntryMakeInAccessible(entry);
+            break;
+        case QCACHE_MSG_DELETE_ALL:
+            ret = qCacheEntryDeleteAllData(entry);
+            break;
+        case QCACHE_MSG_DEBUG:
+            ret = qCacheEntryDebugInfo(entry, ver, 1);
+            break;
+        case QCACHE_MSG_INFO:
+            ret = qCacheEntryDebugInfo(entry, ver, 0);
+            break;
+        default:
+            break;
+    }
+    qCacheEntryDoRoutine(entry);
+
+    return ret;
+}
+
+int qCacheEntryLoadImage(QCacheEntry *entry, u32 cacheFileSize)
+{
+    entry->cacheFileSize = cacheFileSize;
+    qCacheInitMode initMode;
+    int ret = qCacheLocateQCacheFile(entry, &initMode);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheEntryLoadImage(): qCacheLocateQCacheFile failed.");
+        return ret;
+    }
+
+    if (initMode == QCACHE_DATA_INIT) {
+        ret = qCacheImageCreate(entry);
+    } else {
+        ret = qCacheImageRecovery(entry);
+    }
+
+    qCacheUnLocateQCacheFile(entry);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheEntryLoadImage(): qCacheImageCreate failed.");
+        qCacheEntryDestroyInner(entry);
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int sqlite3QCacheCloseProcessEntry(void)
+{
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry) {
+        return SQLITE_OK;
+    }
+
+    return qCacheEntryHandleByType(entry, QCACHE_MSG_EXIT, NULL);
+}
+
+static int sqlite3QCacheEntryCreate(sqlite3 *db, u32 cacheFileSize, QCacheEntry **newEntry)
+{
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    struct timespec startTime;
+    struct timespec endTime;
+    clock_gettime(CLOCK_MONOTONIC, &startTime);
+#endif
+    const char *dbPath = sqlite3_db_filename(db, "main");
+    if (dbPath == NULL) {
+        sqlite3_log(SQLITE_NOTADB, "sqlite3QCacheEntryCreate, sqlite3_db_filename.");
+        return SQLITE_NOTADB;
+    }
+
+    u32 entrySize = (u32)sizeof(QCacheEntry);
+    u8 *tmpEntry = (u8 *)sqlite3_malloc(entrySize);
+    if (tmpEntry == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "sqlite3QCacheEntryCreate, alloc entry.");
+        return SQLITE_NOMEM;
+    }
+    memset(tmpEntry, 0, entrySize);
+    QCacheEntry *curEntry = (QCacheEntry *)tmpEntry;
+
+    int ret = qCacheEntryCreateInner(curEntry, dbPath);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sqlite3QCacheEntryCreate(): qCacheEntryCreateInner failed.");
+        sqlite3_free(tmpEntry);
+        return ret;
+    }
+
+    ret = qCacheEntryLoadImage(curEntry, cacheFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sqlite3QCacheEntryCreate(): qCacheEntryLoadImage.");
+        sqlite3_free(tmpEntry);
+        return ret;
+    }
+
+    *newEntry= curEntry;
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    clock_gettime(CLOCK_MONOTONIC, &endTime);
+    double elapsed = (endTime.tv_sec - startTime.tv_sec) * 1000000.0;
+    elapsed += (endTime.tv_nsec - startTime.tv_nsec) / 1000.0;
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] create new entry cost %f us.", elapsed);
+#endif
+    return SQLITE_OK;
+}
+
+int qCacheCreateProcessEntry(sqlite3 *db, u32 cacheFileSize, QCacheEntry **entry)
+{
+    *entry = NULL;
+    int ret = pthread_mutex_lock(&g_QcacheEntryMutex);
+    if (ret != 0) {
+        sqlite3_log(ret, "qCacheCreateProcessEntry(): write lock, errno %d.", errno);
+        return SQLITE_IOERR;
+    }
+
+    QCacheEntry *glbEntry = sqlite3QCacheGetProcessEntry();
+    if (glbEntry) {
+        *entry = glbEntry;
+        pthread_mutex_unlock(&g_QcacheEntryMutex);
+        return SQLITE_OK;
+    }
+
+    ret = qCacheInitMemBlockPool(QCACHE_SQLSTR_POOL_MAX);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheCreateProcessEntry(): qCacheInitMemBlockPool.");
+        pthread_mutex_unlock(&g_QcacheEntryMutex);
+        return ret;
+    }
+
+    QCacheEntry *newEntry = NULL;
+    ret = sqlite3QCacheEntryCreate(db, cacheFileSize, &newEntry);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheCreateProcessEntry(): create new entry.");
+        qCacheDestroyMemBlockPool();
+        pthread_mutex_unlock(&g_QcacheEntryMutex);
+        return ret;
+    }
+
+    *entry = newEntry;
+    sqlite3QCacheSetProcessEntry(newEntry);
+
+    qCacheRegMemBlockPoolCleanUp();
+    qCacheRegProcessEntryCleanUp();
+
+    pthread_mutex_unlock(&g_QcacheEntryMutex);
+
+    return SQLITE_OK;
+}
+
+int qCacheRebuildProcessEntry(QCacheEntry *entry, u32 cacheFileSize)
+{
+    int ret = pthread_mutex_lock(&g_QcacheEntryMutex);
+    if (ret != 0) {
+        sqlite3_log(ret, "qCacheRebuildProcessEntry(): write lock, errno %d.", errno);
+        return SQLITE_IOERR;
+    }
+
+    qCacheEntryFreeBasic4Free(entry);
+
+    ret = qCacheEntryLoadImage(entry, cacheFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheRebuildProcessEntry(): qCacheEntryLoadImage.");
+        pthread_mutex_unlock(&g_QcacheEntryMutex);
+        return ret;
+    }
+
+    entry->inAccessible = 0;
+    pthread_mutex_unlock(&g_QcacheEntryMutex);
+
+    return SQLITE_OK;
+}
+
+static int qCacheNormalizeWhiteSpace(const char *sql, size_t len, char *result)
+{
+    if (sql == NULL || result == NULL) {
+        return SQLITE_MISUSE;
+    }
+
+    size_t j = 0;
+    int in_string = 0;
+    char quote_char = 0;
+    int need_space = 0;
+    int has_content = 0;
+
+    for (size_t i = 0; i < len; i++) {
+        char c = sql[i];
+        if (!in_string && (c == '\'' || c == '"')) {
+            in_string = 1;
+            quote_char = c;
+            if (need_space && has_content) {
+                result[j++] = ' ';
+                need_space = 0;
+            }
+            result[j++] = c;
+            has_content = 1;
+            continue;
+        } else if (in_string) {
+            result[j++] = c;
+            if (c == quote_char && i + 1 < len && sql[i + 1] == quote_char) {
+                result[j++] = sql[++i];
+                continue;
+            } else if (c == quote_char) {
+                in_string = 0;
+                quote_char = 0;
+            }
+            has_content = 1;
+            continue;
+        }
+
+        if (c == ' ' || c == '\t' || c == '\n' || c == '\r') {
+            if (has_content) {
+                need_space = 1;
+            }
+            if (c == '\r' && i + 1 < len && sql[i + 1] == '\n') {
+                i++;
+            }
+            continue;
+        }
+
+        if (need_space && has_content) {
+            result[j++] = ' ';
+            need_space = 0;
+        }
+
+        result[j++] = c;
+        has_content = 1;
+    }
+
+    result[j] = '\0';
+    if (j > 0 && result[j - 1] == ' ') {
+        result[j - 1] = '\0';
+    }
+
+    return SQLITE_OK;
+}
+
+char *qCacheAllocNormalizedSqlStr(sqlite3_stmt *pStmt)
+{
+    char *sqlStr = sqlite3_expanded_sql(pStmt);
+    if (sqlStr == NULL) {
+        return NULL;
+    }
+
+    size_t allocSize = strlen(sqlStr) + 1;
+    char *result = qCacheMemBlockPoolAllocMem(allocSize);
+    if (!result) {
+        sqlite3_log(SQLITE_NOMEM, "qCacheAllocNormalizedSqlStr(): qCacheMemBlockPoolAllocMem.");
+        return NULL;
+    }
+
+    int ret = qCacheNormalizeWhiteSpace(sqlStr, allocSize - 1, result);
+    sqlite3_free(sqlStr);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheGetNormalizedSqlStr, normalize sql string white space.");
+        return NULL;
+    }
+
+    return result;
+}
+
+void qCacheFreeNormalizedSqlStr(char *sqlStr)
+{
+    if (!sqlStr) {
+        return;
+    }
+
+    qCacheMemBlockPoolFreeMem(sqlStr);
+}
+
+int sqlite3QCacheRegister(sqlite3 *db, const char *hotSql)
+{
+    if (!db || !hotSql) {
+        return SQLITE_MISUSE;
+    }
+
+    QCacheEntry *entry = NULL;
+    int ret = qCacheCreateProcessEntry(db, 0, &entry);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sqlite3QCacheRegister(): qCacheCreateProcessEntry.");
+        return ret;
+    }
+
+    size_t allocSize = strlen(hotSql) + 1;
+    char *normalizedStr = qCacheMemBlockPoolAllocMem(allocSize);
+    if (!normalizedStr) {
+        sqlite3_log(SQLITE_NOMEM, "sqlite3QCacheRegister(): qCacheMemBlockPoolAllocMem.");
+        return SQLITE_NOMEM;
+    }
+
+    ret = qCacheNormalizeWhiteSpace(hotSql, allocSize - 1, normalizedStr);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sqlite3QCacheRegister(): qCacheNormalizeWhiteSpace.");
+        qCacheMemBlockPoolFreeMem(normalizedStr);
+        return ret;
+    }
+
+    ret = qCacheEntryRegisterHotSql(entry, normalizedStr);
+    if (ret != SQLITE_OK) {
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] register SQL error: %s.", normalizedStr);
+#endif
+        sqlite3_log(ret, "sqlite3QCacheRegister(): register normalizedStr.");
+        qCacheMemBlockPoolFreeMem(normalizedStr);
+        return ret;
+    }
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] register SQL ok: %s.", normalizedStr);
+#endif
+
+    qCacheMemBlockPoolFreeMem(normalizedStr);
+    return SQLITE_OK;
+}
+
+int sqlite3QCacheUnRegister(const char *hotSql)
+{
+    if (!hotSql) {
+        return SQLITE_MISUSE;
+    }
+
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry || entry->inAccessible) {
+        sqlite3_log(SQLITE_MISUSE, "sqlite3QCacheUnRegister(): global entry not created.");
+        return SQLITE_MISUSE;
+    }
+
+    size_t allocSize = strlen(hotSql) + 1;
+    char *normalizedStr = qCacheMemBlockPoolAllocMem(allocSize);
+    if (!normalizedStr) {
+        sqlite3_log(SQLITE_NOMEM, "sqlite3QCacheUnRegister(): qCacheMemBlockPoolAllocMem.");
+        return SQLITE_NOMEM;
+    }
+
+    int ret = qCacheNormalizeWhiteSpace(hotSql, allocSize - 1, normalizedStr);
+    if (ret != SQLITE_OK) {
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] unRegister SQL error: %s.", normalizedStr);
+#endif
+        sqlite3_log(ret, "sqlite3QCacheUnRegister(): unRegister normalizedStr.");
+        qCacheMemBlockPoolFreeMem(normalizedStr);
+        return ret;
+    }
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] unRegister SQL ok: %s.", normalizedStr);
+#endif
+    qCacheMemBlockPoolFreeMem(normalizedStr);
+
+    return SQLITE_OK;
+}
+
+int qCacheIsHotSql(QCacheEntry *entry, const char *hotSql, QCacheVersion *ver, u8 *isHot, u8 **dataBuf, u32 *dstBufLen)
+{
+    if (!entry || !hotSql || !isHot || !ver || !dstBufLen || !dataBuf) {
+        return SQLITE_MISUSE;
+    }
+
+    *isHot = 0;
+    *dstBufLen = 0;
+    return qHashTableIsHotSql(&entry->sql2Data, hotSql, ver, isHot, dataBuf, dstBufLen);
+}
+
+static void qCacheResetVdbeMem(Vdbe *v)
+{
+    sqlite3_free(v->pCacheReadBuf);
+    v->pCacheReadBuf = NULL;
+    if (v->aMem) {
+        for (int i = 0; i < v->nMem; i++) {
+            v->aMem[i].flags = MEM_Undefined;
+        }
+    }
+}
+
+/**
+ * |         cacheBuf      |     rowHead  |   columnHead  |    data     |
+ * | totalRows | totalSize | column | len | type |  bytes | column data |
+ */
+int qCacheReadRowFromBuf(Vdbe *v, CacheBuffer *pBuf, int *readPos)
+{
+    if (*readPos >= pBuf->totalSize) {
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        sqlite3_log(SQLITE_ERROR, "[sqlite][qcache]qCache get row end, readPos %d, totalSize %d.",
+          *readPos, pBuf->totalSize);
+#endif
+        qCacheResetVdbeMem(v);
+        return SQLITE_DONE;
+    }
+
+    char *rowPtr = pBuf->data + (*readPos - sizeof(CacheBuffer));
+    RowHeader *rh = (RowHeader *)rowPtr;
+    rowPtr += sizeof(RowHeader);
+
+    v->pResultRow = v->aMem;
+    v->nResColumn = rh->nCol;
+    if (v->nResColumn > v->nMem) {
+        sqlite3_log(SQLITE_CORRUPT, "qCacheReadRowFromBuf(): nCol %d > nMem %d.", v->nResColumn, v->nMem);
+        return SQLITE_CORRUPT;
+    }
+
+    Mem *aCol = v->pResultRow;
+    int rowLenTmp = (int)sizeof(RowHeader);
+    for (int i = 0; i < rh->nCol; i++) {
+        ColHeader *ch = (ColHeader *)rowPtr;
+        rowPtr += sizeof(ColHeader);
+
+        Mem *m = &aCol[i];
+        memset(m, 0, sizeof(Mem));
+        m->flags = ch->type & MEM_TypeMask;
+        if (ch->type == MEM_Int) {
+            m->u.i = *(i64 *)rowPtr;
+        } else if (ch->type == MEM_Real) {
+            m->u.r = *(double *)rowPtr;
+        } else if (ch->type == MEM_Blob) {
+            m->z = rowPtr;
+            m->n = ch->bytes;
+            m->flags = MEM_Blob | MEM_Static;
+        } else if (ch->type == MEM_Str) {
+            m->z = rowPtr;
+            m->n = ch->bytes - 1;
+            m->flags |= MEM_Str | MEM_Static | MEM_Term;
+            m->enc = SQLITE_UTF8;
+        } else if (ch->type == MEM_Null) {
+            // do nothing
+        } else {
+            sqlite3_log(SQLITE_MISMATCH, "unKnown data type.");
+        }
+        rowPtr += ch->bytes;
+        rowLenTmp += ((int)sizeof(ColHeader) + ch->bytes);
+    }
+
+    *readPos += rowLenTmp;
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    sqlite3_log(SQLITE_ERROR, "[sqlite][qcache]qCache get a row: nCol %d, readPos %d, totalSize %d.",
+      v->nResColumn, *readPos, pBuf->totalSize);
+#endif
+
+    return SQLITE_ROW;
+}
+
+int qCachePrepareLocalHotSqlData(sqlite3_stmt *pStmt, Vdbe *v, QCacheVersion *ver, QCacheEntry *entry)
+{
+    if (v->cacheFlags & QCACHE_FLAGS_IS_CHECKED) {
+        return SQLITE_MISMATCH;
+    }
+
+    char *normalizedStr = qCacheAllocNormalizedSqlStr(pStmt);
+    if (normalizedStr == NULL) {
+        return SQLITE_NOMEM;
+    }
+    
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    int errno_0 = errno;
+    struct timespec startTime;
+    struct timespec endTime;
+    clock_gettime(CLOCK_MONOTONIC, &startTime);
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+    u8 isHot = 0;
+    u32 dataLen = 0;
+    u8 *dataBuf = NULL;
+    v->cacheFlags |= QCACHE_FLAGS_IS_CHECKED;
+    int ret = qCacheIsHotSql(entry, normalizedStr, ver, &isHot, &dataBuf, &dataLen);
+    v->cacheFlags |= ((isHot) ? QCACHE_FLAGS_IS_HOTSQL : 0);
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    clock_gettime(CLOCK_MONOTONIC, &endTime);
+    double elapsed = (endTime.tv_sec - startTime.tv_sec) * 1000000.0;
+    elapsed += (endTime.tv_nsec - startTime.tv_nsec) / 1000.0;
+    // DFX
+    int errno_1 = errno;
+    if (isHot) {
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] query SQL hit[1][%u] errno[%d:%d] elapse %f us: %s.",
+          (dataLen > 0), errno_0, errno_1, elapsed, normalizedStr);
+    } else {
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] query SQL hit[0][0] errno[%d:%d] elapse %f us: %s.",
+          errno_0, errno_1, elapsed, normalizedStr);
+    }
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+    qCacheFreeNormalizedSqlStr(normalizedStr);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCachePrepareLocalHotSqlData(): is hot sql.");
+        return ret;
+    }
+
+    if (!dataBuf || !dataLen) {
+        return SQLITE_NOTFOUND;
+    }
+
+    v->pCacheReadBuf = dataBuf;
+    v->cacheReadPos = sizeof(CacheBuffer);
+    return SQLITE_OK;
+}
+
+int sqlite3QCacheIsQueryCase(sqlite3_stmt *pStmt, Vdbe *v)
+{
+    if (!sqlite3_stmt_readonly(pStmt) || v->zSql == NULL) {
+        return 0;
+    }
+
+    char *sqlStr = v->zSql;
+    if ((sqlite3_strnicmp(sqlStr, QCACHE_HOTSQL_PREFIX_1, QCACHE_HOTSQL_PREFIX_1_LEN) == 0) ||
+        (sqlite3_strnicmp(sqlStr, QCACHE_HOTSQL_PREFIX_2, QCACHE_HOTSQL_PREFIX_2_LEN) == 0)) {
+        return 1;
+    }
+
+    return 0;
+}
+
+void sqlite3UpdateQCache2SharedBlock(Vdbe *p)
+{
+#ifdef SQLITE_SHARED_BLOCK_OPTIMIZATION
+  if( !p || !p->pCacheReadBuf ){
+    return;
+  }
+
+  CacheBuffer *pCache = (CacheBuffer *)p->pCacheReadBuf;
+  if( p->pSharedBlock && p->pSharedBlock->pContext && p->pSharedBlock->xFinish ){
+    void *pCtx = p->pSharedBlock->pContext;
+    int totalRecords = pCache->countRows;
+    if( totalRecords == 0 ){
+      totalRecords = pCache->totalRows;
+    }
+    p->pSharedBlock->xFinish(pCtx, totalRecords, totalRecords);
+  }
+#endif /* SQLITE_SHARED_BLOCK_OPTIMIZATION */
+}
+
+void sqlite3UpdateSharedBlock2QCache(Vdbe *p)
+{
+#ifdef SQLITE_SHARED_BLOCK_OPTIMIZATION
+  if( !p || !p->pCacheWriteBuf ){
+    return;
+  }
+
+  CacheBuffer *writeBuf = (CacheBuffer *)p->pCacheWriteBuf;
+  if( p->totalRows>0 ){
+    writeBuf->countRows = p->totalRows;
+  }
+#endif /* SQLITE_SHARED_BLOCK_OPTIMIZATION */
+}
+
+int sqlite3QCacheGetRowData(sqlite3 *db, sqlite3_stmt *pStmt, Vdbe *v, u8 *isGetRow)
+{
+    *isGetRow = 0;
+    if (!pStmt || !v || !db || (v->pCacheWriteBuf)) {
+        return SQLITE_OK;
+    }
+
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry || entry->inAccessible) {
+        return SQLITE_OK;
+    }
+
+    if (!sqlite3QCacheIsQueryCase(pStmt, v)) {
+        return SQLITE_OK;
+    }
+
+    if (!v->pCacheReadBuf) {
+        QCacheVersion version = {0};
+        sqlite3QCacheGetSchemaCookie(db, &version.schemaCookie);
+        sqlite3QCacheGetChangeCounter(db, &version.changeCounter);
+        sqlite3QCacheGetWALSalt(db, &version.walSalt1, &version.walSalt2);
+        int ret = qCachePrepareLocalHotSqlData(pStmt, v, &version, entry);
+        if (ret != SQLITE_OK) {
+            return SQLITE_OK;
+        }
+    }
+
+    *isGetRow = 1;
+    /* Local cache data exists, parse directly from local cache */
+    return qCacheReadRowFromBuf(v, (CacheBuffer *)v->pCacheReadBuf, &v->cacheReadPos);
+}
+
+int qCacheGetResultRowSize(int nCol, Mem *aCol, int *rowSz)
+{
+    int rowSize = sizeof(RowHeader);
+    for (int i = 0; i < nCol; i++) {
+        int dataBytes = 0;
+        Mem *m = &aCol[i];
+        int type = m->flags & MEM_TypeMask;
+        if (type & MEM_Int) {
+            dataBytes = 8;
+        } else if (type & MEM_Real) {
+            dataBytes = 8;
+        } else if (type & MEM_Blob) {
+            dataBytes = m->n;
+        } else if (type & MEM_Str) {
+            dataBytes = m->n + 1;
+        } else if (type & MEM_Null) {
+            dataBytes = 0;
+        } else {
+            sqlite3_log(SQLITE_MISMATCH, "unKnown data type.");
+            return SQLITE_MISMATCH;
+        }
+
+        rowSize += sizeof(ColHeader) + dataBytes;
+    }
+    *rowSz = rowSize;
+    return SQLITE_OK;
+}
+
+int qCacheGetCacheWriteBuffer(Vdbe *v, int rowSz)
+{
+    int totalSize = 0;
+    if (v->cacheFlags & QCACHE_FLAGS_IS_TOOBIG) {
+        return SQLITE_TOOBIG;
+    }
+
+    if (v->pCacheWriteBuf == NULL) {
+        totalSize = (int)sizeof(CacheBuffer) + rowSz;
+    } else {
+        CacheBuffer *writeBuf = (CacheBuffer *)v->pCacheWriteBuf;
+        totalSize = writeBuf->totalSize + rowSz;
+    }
+
+    if (totalSize > (int)HOT_CACHE_BUFFER_SIZE) {
+        sqlite3_log(SQLITE_TOOBIG, "qCacheGetCacheWriteBuffer(): sql data too big.");
+        if (v->pCacheWriteBuf) {
+            sqlite3_free(v->pCacheWriteBuf);
+            v->pCacheWriteBuf = NULL;
+        }
+        v->cacheFlags |= QCACHE_FLAGS_IS_TOOBIG;
+        return SQLITE_TOOBIG;
+    }
+
+    if (v->pCacheWriteBuf == NULL) {
+        v->pCacheWriteBuf = (u8 *)sqlite3_malloc(HOT_CACHE_BUFFER_SIZE);  // sqlite3DbMallocZero
+        if (v->pCacheWriteBuf == NULL) {
+            sqlite3_log(SQLITE_NOMEM, "qCacheGetCacheWriteBuffer(): no memory.");
+            return SQLITE_NOMEM;
+        }
+        memset(v->pCacheWriteBuf, 0, HOT_CACHE_BUFFER_SIZE);
+
+        CacheBuffer *writeBuf = (CacheBuffer *)v->pCacheWriteBuf;
+        writeBuf->totalSize = (int)sizeof(CacheBuffer);
+        sqlite3UpdateSharedBlock2QCache(v);
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheAppend2WriteBuffer(Vdbe *v, int nCol, Mem *aCol, int rowSize)
+{
+    CacheBuffer *cacheBuf = (CacheBuffer *)v->pCacheWriteBuf;
+    char *writePos = cacheBuf->data + (cacheBuf->totalSize - (int)sizeof(CacheBuffer));
+    RowHeader *rh = (RowHeader *)writePos;
+    rh->nCol = nCol;
+    writePos += sizeof(RowHeader);
+
+    for (int i = 0; i < nCol; i++) {
+        Mem *m = &aCol[i];
+        ColHeader ch = {0};
+        ch.type = m->flags & MEM_TypeMask;
+        ch.bytes = 0;
+        void *pData = NULL;
+
+        if (ch.type == MEM_Int) {
+            ch.bytes = 8;
+            pData = &m->u.i;
+        } else if (ch.type == MEM_Real) {
+            ch.bytes = 8;
+            pData = &m->u.r;
+        } else if (ch.type == MEM_Blob) {
+            ch.bytes = m->n;
+            pData = m->z;
+        } else if (ch.type == MEM_Str) {
+            ch.bytes = m->n + 1;
+            pData = m->z;
+        } else if (ch.type == MEM_Null) {
+            ch.bytes = 0;
+        }
+
+        memcpy(writePos, &ch, sizeof(ColHeader));
+        writePos += sizeof(ColHeader);
+        if (ch.bytes > 0 && pData) {
+            memcpy(writePos, pData, ch.bytes);
+            writePos += ch.bytes;
+        }
+    }
+
+    cacheBuf->totalRows++;
+    cacheBuf->totalSize += rowSize;
+    sqlite3UpdateSharedBlock2QCache(v);
+
+    return SQLITE_OK;
+}
+
+/**
+ * |         cacheBuf      |     rowHead  |   columnHead  |    data     |
+ * | totalRows | totalSize | column | len | type |  bytes | column data |
+ */
+int qCacheBufferAppendRowData(Vdbe *v)
+{
+    if (!v) {
+        return SQLITE_OK;
+    }
+
+    int nCol = v->nResColumn;
+    Mem *aCol = v->pResultRow;
+    if (nCol == 0 || aCol == NULL) {
+        return SQLITE_OK;
+    }
+
+    int rowSize = 0;
+    int ret = qCacheGetResultRowSize(nCol, aCol, &rowSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheBufferAppendRowData(): get row size.");
+        return ret;
+    }
+
+    ret = qCacheGetCacheWriteBuffer(v, rowSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheBufferAppendRowData(): get cache buffer.");
+        return ret;
+    }
+
+    return qCacheAppend2WriteBuffer(v, nCol, aCol, rowSize);
+}
+
+int sqlite3QCacheProcessAfterStep(sqlite3 *db, sqlite3_stmt *pStmt, Vdbe *v, int rc)
+{
+    if (!pStmt || !v || !db) {
+        return SQLITE_OK;
+    }
+
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry || entry->inAccessible) {
+        return SQLITE_OK;
+    }
+
+    if (!sqlite3QCacheIsQueryCase(pStmt, v)) {
+        return SQLITE_OK;
+    }
+
+    qCacheEntryDoRoutine(entry);
+
+    // only for query action
+    int ret = SQLITE_OK;
+    if (rc == SQLITE_ROW && (v->cacheFlags & QCACHE_FLAGS_IS_HOTSQL)) {
+        ret = qCacheBufferAppendRowData(v);
+    } else if (rc == SQLITE_DONE && v->pCacheWriteBuf) {
+        QCacheVersion version = {0};
+        sqlite3QCacheGetSchemaCookie(db, &version.schemaCookie);
+        sqlite3QCacheGetChangeCounter(db, &version.changeCounter);
+        sqlite3QCacheGetWALSalt(db, &version.walSalt1, &version.walSalt2);
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        struct timespec startTime;
+        struct timespec endTime;
+        clock_gettime(CLOCK_MONOTONIC, &startTime);
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+        CacheBuffer *pCache = (CacheBuffer *)v->pCacheWriteBuf;
+        char *normalizedStr = qCacheAllocNormalizedSqlStr(pStmt);
+        ret = qCacheEntryUpdateHotSqlData(entry, normalizedStr, v->pCacheWriteBuf, pCache->totalSize, &version);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "sqlite3QCacheProcessAfterStep(): qCacheEntryUpdateHotSqlData.");
+        }
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        clock_gettime(CLOCK_MONOTONIC, &endTime);
+        double elapsed = (endTime.tv_sec - startTime.tv_sec) * 1000000.0;
+        elapsed += (endTime.tv_nsec - startTime.tv_nsec) / 1000.0;
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] sqlite done update SQL data[%d:%d] elapse %f us: %s.",
+            pCache->totalRows, pCache->totalSize, elapsed, normalizedStr);
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+        sqlite3_free(v->pCacheWriteBuf);
+        v->pCacheWriteBuf = NULL;
+        qCacheFreeNormalizedSqlStr(normalizedStr);
+    } else {
+        ret = rc;
+    }
+
+    return ret;
+}
+
+void sqlite3QCacheBufReset(sqlite3 *db, sqlite3_stmt *pStmt)
+{
+    if (!db || !pStmt) {
+        return;
+    }
+
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry) {
+        return;
+    }
+
+    Vdbe *v = (Vdbe *)pStmt;
+    if (v->pCacheReadBuf) {
+        sqlite3_free(v->pCacheReadBuf);  // sqlite3DbFree
+        v->pCacheReadBuf = NULL;
+    }
+    v->cacheReadPos = 0;
+    v->cacheFlags = 0;
+
+    if (!v->pCacheWriteBuf) {
+        return;
+    }
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    struct timespec startTime;
+    struct timespec endTime;
+    clock_gettime(CLOCK_MONOTONIC, &startTime);
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+    QCacheVersion version = {0};
+    sqlite3QCacheGetSchemaCookie(db, &version.schemaCookie);
+    sqlite3QCacheGetChangeCounter(db, &version.changeCounter);
+    sqlite3QCacheGetWALSalt(db, &version.walSalt1, &version.walSalt2);
+    CacheBuffer *pCache = (CacheBuffer *)v->pCacheWriteBuf;
+    char *normalizedStr = qCacheAllocNormalizedSqlStr(pStmt);
+    int ret = qCacheEntryUpdateHotSqlData(entry, normalizedStr, v->pCacheWriteBuf, pCache->totalSize, &version);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "sqlite3QCacheBufReset(): qCacheEntryUpdateHotSqlData.");
+    }
+
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+        clock_gettime(CLOCK_MONOTONIC, &endTime);
+        double elapsed = (endTime.tv_sec - startTime.tv_sec) * 1000000.0;
+        elapsed += (endTime.tv_nsec - startTime.tv_nsec) / 1000.0;
+        qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] sqlite reset update SQL data[%d:%d] elapse %f us: %s.",
+            pCache->totalRows, pCache->totalSize, elapsed, normalizedStr);
+#endif // SQLITE_QUERY_CACHE_DEBUG
+
+    qCacheFreeNormalizedSqlStr(normalizedStr);
+    sqlite3_free(v->pCacheWriteBuf);  // sqlite3DbFree
+    v->pCacheWriteBuf = NULL;
+}
+
+static int QCacheStr2UintSafe(const char *s, unsigned int *out)
+{
+    if (!s || !out) {
+        return SQLITE_ERROR;
+    }
+
+    char *end;
+    errno = 0;
+    unsigned long val = strtoul(s, &end, 10);
+    if (end == s) {
+        return SQLITE_ERROR;
+    }
+    if (*end != 0) {
+        return SQLITE_ERROR;
+    }
+    if (errno == ERANGE) {
+        return SQLITE_ERROR;
+    }
+    if (val > UINT_MAX) {
+        return SQLITE_ERROR;
+    }
+
+    *out = (unsigned int)val;
+    return SQLITE_OK;
+}
+
+int sqlite3QCacheEntrySetTtlcycle(const char *zTimeStr)
+{
+    if (!zTimeStr) {
+        return SQLITE_OK;
+    }
+
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry || entry->inAccessible) {
+        return SQLITE_OK;
+    }
+
+    u32 invalidPeriod = 0;
+    if (QCacheStr2UintSafe(zTimeStr, (u32 *)&invalidPeriod) == SQLITE_OK) {
+        entry->ttlCycle = invalidPeriod;
+    }
+
+    return SQLITE_OK;
+}
+
+int sqlite3QCacheEntryCreateBySize(sqlite3 *db, const char *cacheSize)
+{
+    if (!db || !cacheSize) {
+        return SQLITE_OK;
+    }
+
+    u32 cacheFileSizeKB = 0;
+    if (QCacheStr2UintSafe(cacheSize, (u32 *)&cacheFileSizeKB) != SQLITE_OK) {
+        return SQLITE_ERROR;
+    }
+    u32 cacheFileSizeBytes = QCACHE_ALIGN_UP_TO_4KB_BYTES(cacheFileSizeKB);
+
+    int ret = SQLITE_OK;
+    QCacheEntry *entry = sqlite3QCacheGetProcessEntry();
+    if (!entry) {
+        ret = qCacheCreateProcessEntry(db, cacheFileSizeBytes, &entry);
+        if (ret != SQLITE_OK) {
+            sqlite3_log(ret, "sqlite3QCacheEntryCreateBySize(): qCacheCreateProcessEntry.");
+            return ret;
+        }

 #endif /* SQLITE_PAGER_H */
 
 /************** End of pager.h ***********************************************/
@@ -17918,6 +17924,9 @@ SQLITE_PRIVATE char *sqlite3BinlogGetNthColForSearch(sqlite3 *db, const Table *p
 /************** Binlog typedef in sqlite3 END ************************************/
 #endif
 
+#ifdef SQLITE_QUERY_CACHE

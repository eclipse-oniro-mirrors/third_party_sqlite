+int qCacheImageCreate(QCacheEntry *entry)
+{
+    int ret = ftruncate(entry->fd, entry->cacheFileSize);
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR, "qCacheImageCreate(): truncate failed, %s", strerror(errno));
+        return SQLITE_IOERR;
+    }
+
+    ret = qHashTableInit(&entry->sql2Data, entry->fd, entry->qCacheMemSize, entry->cacheFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageCreate(): sharePageInit failed.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheImageRebuild4Free(QCacheEntry *entry, int fd)
+{
+    u32 newPgSize = 0;
+    int ret = qHashTableAttach4Free(&entry->sql2Data,
+        fd,
+        entry->qCacheMemSize,
+        entry->cacheFileSize,
+        entry->isMultiInst,
+        &newPgSize);
+    if (ret == SQLITE_OK) {
+        return qHashTableCompressRebuild4Free(&entry->sql2Data, 0);
+    }
+
+    if (newPgSize == 0) {
+        sqlite3_log(ret, "qCacheImageRebuild4Free(): qHashTableAttach4Free.");
+        return ret;
+    }
+
+    /* Initial attach failed, the shared memory page has changed, need to re-attach */
+    ret = qHashTableAttach4Free(
+        &entry->sql2Data, fd, newPgSize, entry->cacheFileSize, entry->isMultiInst, &newPgSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRebuild4Free(): qHashTableAttach4Free second.");
+        return ret;
+    }
+    entry->qCacheMemSize = newPgSize;
+
+    ret = qHashTableCompressRebuild4Free(&entry->sql2Data, 0);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRebuild4Free(): qHashTableCompressRebuild4Free second.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheImageExpand(QCacheEntry *entry)
+{
+    u32 oldFileSize = SQLITE_MAX_U32;
+    int ret = getCacheFileSize(entry->QCacheMapFPath, &oldFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageExpand(): stat failed.");
+    }
+
+    if (oldFileSize < SHARED_BLOCK_PAGE_STEP_SIZE) {
+        ret = SQLITE_IOERR;
+        sqlite3_log(ret, "qCacheImageRecoverySafe(): file size.");
+        return ret;
+    }
+
+    if (oldFileSize < entry->cacheFileSize) {
+        ret = ftruncate(entry->fd, entry->cacheFileSize);
+        if (ret != 0) {
+            sqlite3_log(SQLITE_IOERR, "qCacheImageExpand(): ftruncate failed, %s", strerror(errno));
+            return SQLITE_IOERR;
+        }
+    }
+
+    ret = qCacheImageRebuild4Free(entry, entry->fd);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageExpand(): map failed.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheImageNormal(QCacheEntry *entry)
+{
+    u32 oldFileSize = SQLITE_MAX_U32;
+    int ret = getCacheFileSize(entry->QCacheMapFPath, &oldFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageNormal(): stat failed.");
+    }
+
+    if (oldFileSize < SHARED_BLOCK_PAGE_STEP_SIZE) {
+        sqlite3_log(ret, "qCacheImageRecoverySafe(): file size.");
+        return SQLITE_IOERR;
+    }
+
+    ret = qCacheImageRebuild4Free(entry, entry->fd);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageNormal(): map failed.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheImageRecoverySafe(QCacheEntry *entry)
+{
+    u32 oldFileSize = 0;
+    int ret = getCacheFileSize(entry->QCacheMapFPath, &oldFileSize);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRecoverySafe(): stat failed.");
+        return ret;
+    }
+
+    u32 newFileSize = entry->cacheFileSize;
+    if (newFileSize > oldFileSize) {
+        /* Expand the cache file if needed */
+        ret = qCacheImageExpand(entry);
+    } else {
+        /* Normal recovery, no shrinking allowed for multi-process concurrency */
+        ret = qCacheImageNormal(entry);
+    }
+
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRecoverySafe(): recovery.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+void qCacheEntryFreeBasic4Free(QCacheEntry *entry)
+{
+    qHashTableDestroy4Free(&entry->sql2Data);
+    if (entry->fd != -1) {
+        close(entry->fd);
+        entry->fd = -1;
+    }
+
+    if (entry->multiInstFd != -1) {
+        close(entry->multiInstFd);
+        entry->multiInstFd = -1;
+    }
+}
+
+void qCacheEntryDestroyInner(QCacheEntry *entry)
+{
+    qCacheEntryFreeBasic4Free(entry);
+    if (entry->QCacheMapFPath != NULL) {
+        sqlite3_free(entry->QCacheMapFPath);
+        entry->QCacheMapFPath = NULL;
+    }
+
+    if (entry->QCacheInsFlock != NULL) {
+        sqlite3_free(entry->QCacheInsFlock);
+        entry->QCacheInsFlock = NULL;
+    }
+}
+
+int qCacheImageRecoveryInner(QCacheEntry *entry)
+{
+    int ret = qCacheImageRecoverySafe(entry);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRecoveryInner(): recover.");
+        qHashTableDestroy4Free(&entry->sql2Data);
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheImageRecovery(QCacheEntry *entry)
+{
+    int ret = qCacheImageRecoveryInner(entry);
+    if (ret == SQLITE_OK) {
+        return ret;
+    }
+
+    if (entry->isMultiInst) {
+        return ret;
+    }
+
+    ret = qCacheImageCreate(entry);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheImageRecovery(): image create.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheGetCacheFileAtomicly(QCacheEntry *entry, int *exists)
+{
+    int ret = 0;
+    *exists = 0;
+    mode_t mode = entry->dbFstat.st_mode;
+    int fd = open(entry->QCacheMapFPath, O_RDWR | O_CREAT | O_EXCL | O_TRUNC, mode);
+    if (fd >= 0) {
+        if (entry->dbFstat.st_uid != (uid_t)-1 && entry->dbFstat.st_gid != (gid_t)-1) {
+            ret = fchown(fd, entry->dbFstat.st_uid, entry->dbFstat.st_gid);
+            if (ret != 0) {
+                sqlite3_log(SQLITE_IOERR, "qCacheGetCacheFileAtomicly(): fchown failed, %s", strerror(errno));
+            }
+        }
+
+        ret = sharePageWRLock(fd, QCACHE_PAGE_WLOCK);
+        if (ret != 0) {
+            sqlite3_log(SQLITE_IOERR_LOCK, "qCacheGetCacheFileAtomicly(): flock failed, %s", strerror(errno));
+            close(fd);
+            return SQLITE_IOERR_LOCK;
+        }
+
+        entry->fd = fd;
+        return SQLITE_OK;
+    }
+
+    if (errno != EEXIST) {
+        sqlite3_log(SQLITE_IOERR, "qCacheGetCacheFileAtomicly(): open failed, %s", strerror(errno));
+        return SQLITE_IOERR;
+    }
+
+    fd = open(entry->QCacheMapFPath, O_RDWR);
+    if (fd < 0) {
+        sqlite3_log(SQLITE_IOERR, "qCacheGetCacheFileAtomicly(): open existed file failed, %s", strerror(errno));
+        return SQLITE_IOERR;
+    }
+
+    ret = sharePageWRLock(fd, QCACHE_PAGE_WLOCK);
+    if (ret != 0) {
+        sqlite3_log(SQLITE_IOERR_LOCK, "qCacheGetCacheFileAtomicly(): flock existed file failed, %s", strerror(errno));
+        close(fd);
+        return SQLITE_IOERR_LOCK;
+    }
+
+    *exists = 1;
+    entry->fd = fd;
+    return SQLITE_OK;
+}
+
+int qCacheLocateQCacheFile(QCacheEntry *entry, qCacheInitMode *initMode)
+{
+    u32 flockFpathLen = strlen(entry->QCacheMapFPath) + strlen(QCACHE_INSTANCE_LOCK_SUFFIX) + 1;
+    char *flockFpath = (char *)sqlite3_malloc(flockFpathLen);
+    if (flockFpath == NULL) {
+        sqlite3_log(SQLITE_NOMEM, "qCacheLocateQCacheFile(): create lock file path.");
+        return SQLITE_NOMEM;
+    }
+    strcpy(flockFpath, entry->QCacheMapFPath);
+    strcat(flockFpath, QCACHE_INSTANCE_LOCK_SUFFIX);
+    entry->QCacheInsFlock = flockFpath;
+
+    u32 fileSize = (entry->cacheFileSize > 0) ? entry->cacheFileSize : DEFAULT_CACHE_FILE_SIZE;
+    fileSize = (fileSize > SHARED_BLOCK_PAGE_STEP_SIZE) ? fileSize : SHARED_BLOCK_PAGE_STEP_SIZE;
+    entry->cacheFileSize = fileSize;
+    entry->qCacheMemSize = SHARED_BLOCK_PAGE_STEP_SIZE;
+
+    int exists = 0;
+    int ret = qCacheGetCacheFileAtomicly(entry, &exists);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(SQLITE_IOERR, "qCacheLocateQCacheFile(): qCacheGetCacheFileAtomicly failed.");
+        return SQLITE_IOERR;
+    }
+
+    *initMode = exists ? QCACHE_DATA_RECOVERY : QCACHE_DATA_INIT;
+    return SQLITE_OK;
+}
+
+void qCacheUnLocateQCacheFile(QCacheEntry *entry)
+{
+    sharePageUnLock(entry->fd);
+}
+
+int qCacheEntryMakeInAccessible(QCacheEntry *entry)
+{
+    if (!entry) {
+        return SQLITE_OK;
+    }
+
+    entry->inAccessible = 0;
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] qcache entry Disabled, inAccessible = %d.", entry->inAccessible);
+#endif /* SQLITE_QUERY_CACHE_DEBUG */
+    return SQLITE_OK;
+}
+
+/*
+** Register a hot SQL statement.
+** Add to cache if not present; ignore if already exists.
+*/
+int qCacheEntryRegisterHotSql(QCacheEntry *entry, const char *hotSql)
+{
+    if (!entry || !hotSql) {
+        sqlite3_log(SQLITE_MISUSE, "qCacheEntryRegisterHotSql(): invalid para.");
+        return SQLITE_MISUSE;
+    }
+
+    return qHashTableInsertSql(&entry->sql2Data, hotSql);
+}
+
+/*
+** Unregister a hot SQL statement.
+** Remove from cache if present; ignore if not found.
+*/
+int qCacheEntryUnRegisterHotSql(QCacheEntry *entry, const char *hotSql)
+{
+    if (!entry || !hotSql) {
+        sqlite3_log(SQLITE_MISUSE, "qCacheEntryUnRegisterHotSql(): invalid para.");
+        return SQLITE_MISUSE;
+    }
+
+    return qHashTableDeleteSql(&(entry->sql2Data), hotSql);
+}
+
+/*
+** Store data for a hot SQL into the cache.
+** Ignore if SQL is not hot; otherwise cache the data and rebuild mappings.
+*/
+int qCacheEntryUpdateHotSqlData(QCacheEntry *entry, const char *hotSql, u8 *data, u32 dataLen, QCacheVersion *ver)
+{
+    if (!entry || !hotSql || !data || !ver) {
+        sqlite3_log(SQLITE_MISUSE, "qCacheEntryUpdateHotSqlData(): invalid para.");
+        return SQLITE_MISUSE;
+    }
+
+    return qHashTableUpdateSqlData(&entry->sql2Data, hotSql, data, dataLen, ver);
+}
+
+int qCacheEntryDeleteAllData(QCacheEntry *entry)
+{
+#ifdef SQLITE_QUERY_CACHE_DEBUG
+    qCachePrintFulllog(SQLITE_ERROR, "[sqlite][qcache] qcache entry Delete data.");
+#endif /* SQLITE_QUERY_CACHE_DEBUG */
+
+    int ret = qHashTableDeleteAllNodeData(&entry->sql2Data);
+    if (ret != SQLITE_OK) {
+        sqlite3_log(ret, "qCacheEntryDeleteAllData(): qHashTable Delete data.");
+        return ret;
+    }
+
+    return SQLITE_OK;
+}
+
+int qCacheEntryDebugInfo(QCacheEntry *entry, QCacheVersion *ver, u32 isDebug)
+{
+    qCacheDebugAppend("\n======Dump Qcache Start======\n");
+    if (isDebug) {
+        qCacheDebugAppend("fd           : %u\n", entry->fd);
+        qCacheDebugAppend("isMultiInst  : %u\n", entry->isMultiInst);
+        qCacheDebugAppend("multiInstFd  : %d\n", entry->multiInstFd);
+        qCacheDebugAppend("currVersion  : [%4u, %5u, %10u, %10u]\n", ver->schemaCookie, ver->changeCounter,
+            ver->walSalt1, ver->walSalt2);
+    }
+    qCacheDebugAppend("ttlCycle     : %u(s)\n", entry->ttlCycle);
+    if (isDebug) {
+        qCacheDebugAppend("qCacheMemSize: %u(B)\n", entry->qCacheMemSize);
+        qCacheDebugAppend("cacheFileSize: %u(B)\n", entry->cacheFileSize);
+        qCacheDebugAppend("inAccessible : %d\n", entry->inAccessible);
+        qCacheDebugAppend("QCacheMapFPath: %s\n", entry->QCacheMapFPath);
+        qCacheDebugAppend("QCacheInsFlock: %s\n", entry->QCacheInsFlock);
+    }
+
+    if (isDebug) {
+        (void)qHashTableDumpBasic(&entry->sql2Data);
+    } else {
+        (void)qHashTableDumpSQL(&entry->sql2Data);
+    }
+
+    qCacheDebugAppend("======Dump Qcache End======\n\n");
+    qCacheDebugPrint();
+
+    return SQLITE_OK;
+}
